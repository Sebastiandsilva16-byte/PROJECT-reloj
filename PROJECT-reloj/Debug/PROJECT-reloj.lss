                                 DELAY_10MS_LOOP2:
000232 951a                          DEC R17
000233 f7f1                          BRNE DELAY_10MS_LOOP2
000234 950a                          DEC R16
000235 f7d9                          BRNE DELAY_10MS_LOOP1
                                 	
000236 b113                      	IN	R17, PINB			 // Leer estado de los botones
000237 9310 0108                 	STS	Botonespressint, R17 // Guardar en variable de interrupción
000239 9100 0108                 	LDS R16, Botonespressint
00023b 9300 010a                     STS Botonespresspasado2, R16
                                 
                                 	// Comparar con el valor pasado	
00023d 9100 0109                 	LDS R16, Botonespresspasado
00023f 9110 010a                 	LDS R17, Botonespresspasado2
                                 
000241 1701                          CP R16, R17            // Comparara el estado pasado con el presente
000242 f469                          BRNE FINBOTONES            // Si son diferentes, salir
                                 	
000243 2f30                      	MOV R19, R16   // se guardan los verdaderos valores del boton
                                 	
000244 ff30                      	SBRS R19, PB0
