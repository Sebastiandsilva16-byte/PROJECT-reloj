0001a3 9380 0106                     STS unidadesMES, R24    // Guardar Unidades de MES
0001a5 93a0 0107                     STS decenasMES, R26     // Guardar Decenas de MES
0001a7 9508                          RET
                                 
                                 
                                 // Rutina de interrupci?n del Timer1 - Modo COMPARE MATCH
                                 TIMER1_COMPA:      
0001a8 930f                          PUSH R16
0001a9 b70f                          IN R16, SREG
0001aa 930f                          PUSH R16
                                 
                                 
0001ab 9513                          INC R17                 // Incrementar contador de ciclos
0001ac 9a1d                      	SBI PINB, PINB5			// titila cada que pasa un seg
                                 
0001ad 910f                      	POP R16      
0001ae bf0f                      	OUT SREG, R16 
0001af 910f                      	POP R16     
0001b0 9518                      	RETI
                                 
                                 // Rutina de interrupcion del PORTB
                                 INTBOTONES:
0001b1 930f                      	PUSH R16
0001b2 b70f                      	IN R16, SREG
0001b3 930f                      	PUSH R16	
0001b4 931f                      	PUSH R17
                                 	
0001b5 b113                      	IN	R17, PINB			 // Leer estado de los botones
0001b6 9310 0108                 	STS	Botonespressint, R17 // Guardar en variable de interrupción
                                 	//guarda el estado pasado de los botones
0001b8 9100 0108                 	LDS R16, Botonespressint
0001ba 9300 0109                     STS Botonespresspasado, R16
                                 	
0001bc e608                      	LDI R16, 104     // 10ms 
                                 DELAY_10MS_LOOP1:
0001bd ef1f                          LDI R17, 255     // Loop interno
                                 DELAY_10MS_LOOP2:
0001be 951a                          DEC R17
0001bf f7f1                          BRNE DELAY_10MS_LOOP2
0001c0 950a                          DEC R16
0001c1 f7d9                          BRNE DELAY_10MS_LOOP1
                                 	
0001c2 b113                      	IN	R17, PINB			 // Leer estado de los botones
0001c3 9310 0108                 	STS	Botonespressint, R17 // Guardar en variable de interrupción
0001c5 9100 0108                 	LDS R16, Botonespressint
0001c7 9300 010a                     STS Botonespresspasado2, R16
                                 
                                 	// Comparar con el valor pasado	
0001c9 9100 0109                 	LDS R16, Botonespresspasado
0001cb 9110 010a                 	LDS R17, Botonespresspasado2
                                 
0001cd 1701                          CP R16, R17            // Comparara el estado pasado con el presente
0001ce f469                          BRNE FINBOTONES            // Si son diferentes, salir
                                 	
0001cf 2f30                      	MOV R19, R16   // se guardan los verdaderos valores del boton
                                 	
0001d0 ff30                      	SBRS R19, PB0
0001d1 940e 01e1                 	CALL boton_PB0
0001d3 ff31                      	SBRS R19, PB1
0001d4 940e 01e3                 	CALL boton_PB1
0001d6 ff32                      	SBRS R19, PB2
0001d7 940e 01e5                 	CALL boton_PB2
0001d9 ff33                      	SBRS R19, PB3
0001da 940e 01e7                 	CALL boton_PB3
                                 
                                 	FINBOTONES:
                                 
0001dc 911f                      	POP R17
0001dd 910f                      	POP R16
0001de bf0f                      	OUT SREG, R16
0001df 910f                      	POP R16
0001e0 9518                      	RETI
                                 
