000470 2711                      	CLR	R17
000471 c003                      	RJMP Nocontar
                                 	Sicontar:
                                 
000472 3716                      	CPI R17, 118 //segundos (118) (1 para pruebas de dia y mes)
000473 f0c0                          BRLO TIMER_RET
000474 2711                      	CLR R17
                                 
                                 	Nocontar:
                                 
                                 	//Unidades de Minutos
000475 9523                      	INC R18
