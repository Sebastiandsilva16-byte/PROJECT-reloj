000492 9523                      	INC R18           // Si R27 está activo, sumar 1 a R18
000493 27bb                      	CLR R27
                                 
000494 940e 04ef                 	CALL LOGDIAS			//para ver como se debe efectuar la suma de dias
                                 
000496 91c0 0110                 	LDS R28, Mes
000498 30c0                      	CPI R28, 0  
000499 f149                          BREQ TREINTA_Y_UN_DIAS
                                     
