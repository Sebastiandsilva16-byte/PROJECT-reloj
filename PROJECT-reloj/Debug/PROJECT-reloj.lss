                                 // Rutina de interrupci?n del Timer1 - Modo COMPARE MATCH
                                 // Se encarga de contar los segundos
                                 TIMER1_COMPA:      
000573 932f                          PUSH R18
000574 b72f                          IN R18, SREG
000575 932f                          PUSH R18
                                 
