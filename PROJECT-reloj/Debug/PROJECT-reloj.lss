00049c 30c2                          CPI R28, 2  
00049d f0a1                          BREQ VEINTIOCHO_DIAS
                                 
                                 
                                 TREINTA_DIAS: // Aquí va la lógica para meses de 30 días ----------------------------------------------
00049e 3063                      	CPI R22, 3
00049f f029                      	BREQ TREINTA
0004a0 302a                      	CPI R18, 10          // Comparar R18 (unidades de día) con 10
0004a1 f078                      	BRLO TEMPORAL      
0004a2 2722                      	CLR R18              
0004a3 9563                      	INC R22
0004a4 c006                      	RJMP TREINTAFIN
                                 	TREINTA:
