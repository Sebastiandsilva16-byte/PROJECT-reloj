000480 9310 0108                 	STS	Botonespressint, R17 // Guardar en variable de interrupción
                                 	//guarda el estado pasado de los botones
000482 9100 0108                 	LDS R16, Botonespressint
000484 9300 0109                     STS Botonespresspasado, R16
                                 	
000486 e608                      	LDI R16, 104     // 10ms 
