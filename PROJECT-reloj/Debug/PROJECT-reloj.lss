                                 // Rutina de interrupci?n del Timer1 - Modo COMPARE MATCH
                                 // Se encarga de contar los segundos
                                 TIMER1_COMPA:      
00051b 930f                          PUSH R16
00051c b70f                          IN R16, SREG
00051d 930f                          PUSH R16
                                 
                                 
00051e 9513                          INC R17                 // Incrementar contador de ciclos
00051f 9a1d                      	SBI PINB, PINB5			// titila cada que pasa un seg
                                 
000520 910f                      	POP R16      
000521 bf0f                      	OUT SREG, R16 
000522 910f                      	POP R16     
000523 9518                      	RETI
                                 
                                 // Rutina de interrupcion del PORTB
                                 // La logica de los botones
                                 INTBOTONES:
000524 930f                      	PUSH R16
000525 b70f                      	IN R16, SREG
000526 930f                      	PUSH R16	
000527 931f                      	PUSH R17
                                 	
000528 b113                      	IN	R17, PINB			 // Leer estado de los botones
000529 9310 0108                 	STS	Botonespressint, R17 // Guardar en variable de interrupción
                                 	//guarda el estado pasado de los botones
00052b 9100 0108                 	LDS R16, Botonespressint
00052d 9300 0109                     STS Botonespresspasado, R16
                                 	
00052f e608                      	LDI R16, 104     // 10ms 
                                 DELAY_10MS_LOOP1:
000530 ef1f                          LDI R17, 255     // Loop interno
                                 DELAY_10MS_LOOP2:
000531 951a                          DEC R17
000532 f7f1                          BRNE DELAY_10MS_LOOP2
000533 950a                          DEC R16
000534 f7d9                          BRNE DELAY_10MS_LOOP1
                                 	
000535 b113                      	IN	R17, PINB			 // Leer estado de los botones
000536 9310 0108                 	STS	Botonespressint, R17 // Guardar en variable de interrupción
000538 9100 0108                 	LDS R16, Botonespressint
00053a 9300 010a                     STS Botonespresspasado2, R16
                                 
                                 	// Comparar con el valor pasado	
00053c 9100 0109                 	LDS R16, Botonespresspasado
00053e 9110 010a                 	LDS R17, Botonespresspasado2
                                 
000540 1701                          CP R16, R17            // Comparara el estado pasado con el presente
000541 f529                          BRNE FINBOTONES            // Si son diferentes, salir
                                 	
000542 2f30                      	MOV R19, R16   // se guardan los verdaderos valores del boton
                                 	
                                 // Guardar bit PB0
000543 fb30                      BST R19, 0          // Store bit from register T flag (PB0)
000544 f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
000545 93c0 0112                 STS PBceroB, R28    // Store R28 en variable PBceroB
                                 
                                 // Guardar bit PB1
000547 fb31                      BST R19, 1          // Store bit from register T flag (PB1)
000548 f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
000549 93c0 0113                 STS PBunoB, R28     // Store R28 en variable PBunoB
                                 
                                 // Guardar bit PB2
00054b fb32                      BST R19, 2          // Store bit from register T flag (PB2)
00054c f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
00054d 93c0 0114                 STS PBdosB, R28     // Store R28 en variable PBdosB
                                 
                                 // Guardar bit PB3
00054f fb33                      BST R19, 3          // Store bit from register T flag (PB3)
000550 f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
000551 93c0 0115                 STS PBtresB, R28    // Store R28 en variable PBtresB
                                 
                                 // Cargar las variables en R28 y evaluar con SBRC
000553 91c0 0112                 LDS R28, PBceroB    // Cargar PBceroB en R28
000555 ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
000556 940e 056c                 CALL boton_PB0
                                 
000558 91c0 0113                 LDS R28, PBunoB     // Cargar PBunoB en R28
00055a ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
00055b 940e 056e                 CALL boton_PB1
                                 
00055d 91c0 0114                 LDS R28, PBdosB     // Cargar PBdosB en R28
00055f ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
000560 940e 0577                 CALL boton_PB2
                                 
000562 91c0 0115                 LDS R28, PBtresB    // Cargar PBtresB en R28
000564 ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
000565 940e 0582                 CALL boton_PB3
                                 
                                 	FINBOTONES:
                                 
000567 911f                      	POP R17
000568 910f                      	POP R16
000569 bf0f                      	OUT SREG, R16
00056a 910f                      	POP R16
00056b 9518                      	RETI
                                 
                                 boton_PB0://----------------------------
                                 	
00056c 9543                      	INC R20       //Cambia de modo
                                     
00056d 9508                      	RET
                                 
