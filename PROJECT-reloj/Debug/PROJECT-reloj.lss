00024d ff33                      	SBRS R19, PB3
00024e 940e 026b                 	CALL boton_PB3
                                 
                                 	FINBOTONES:
                                 
000250 911f                      	POP R17
000251 910f                      	POP R16
000252 bf0f                      	OUT SREG, R16
000253 910f                      	POP R16
000254 9518                      	RETI
                                 
