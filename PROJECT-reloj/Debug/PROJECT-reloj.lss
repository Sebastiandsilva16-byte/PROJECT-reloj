0004cb e021                      	LDI R18, 1    
0004cc 2766                      	CLR R22              
0004cd 9583                      	INC R24              // Incrementar unidades de mes 
                                 MESLOG: //ahora va a ver la logica de los meses
0004ce 940e 0502                 	CALL MESLOG2
                                 	   
0004d0 91c0 0111                 	LDS R28, Mess
0004d2 30c0                      	CPI R28, 0  
0004d3 f011                          BREQ MESNORMAL
                                     
0004d4 30c1                          CPI R28, 1
0004d5 f039                          BREQ MES10
                                 		
                                 	MESNORMAL:
0004d6 308a                      	CPI R24, 10          // si alcanzan las decenas suma 1
0004d7 f058                      	BRLO TIMER_RET2      
0004d8 2788                      	CLR R24            
0004d9 95a3                      	INC R26              // Incrementar decenas de mes      
0004da 2766                      	CLR R22
0004db e021                      	LDI R18, 1 
0004dc c006                      	RJMP TIMER_RET2
                                 
                                 	MES10:
0004dd 3083                      	CPI R24, 3          // si alcanza 3 reinicia
0004de f020                      	BRLO TIMER_RET2      
0004df e081                      	LDI R24, 1            
0004e0 27aa                      	CLR R26   
0004e1 2766                      	CLR R22
0004e2 e021                      	LDI R18, 1    	 
                                 TIMER_RET2:
0004e3 940e 050c                 	CALL cerocero
0004e5 940e 00ea                 	CALL SAVEDM
0004e7 9508                          RET
                                 
                                 //--------------------------------------------------------------------------------------------------------LOGICA DE DIAS
                                 // Mes-->  (0) 31 dias (1) 30 dias (2) 28 dias
                                 LOGDIAS:
                                 	// Verificar condiciones para saltar a 30dias
0004e8 3084                      	CPI R24, 4        // żR24 es 4 (abril)?
0004e9 f081                      	BREQ MESUNO
0004ea 3086                      	CPI R24, 6        // żR24 es 6 (junio)?
0004eb f071                      	BREQ MESUNO
0004ec 3089                      	CPI R24, 9        // żR24 es 9 (septiembre)?
0004ed f061                      	BREQ MESUNO
                                 
                                 	// Verificar si R26=1 y R24=1 (noviembre)
0004ee 30a1                      	CPI R26, 1        // żR26 es 1?
0004ef f421                      	BRNE VERIFICAR_28 // Si R26 no es 1, seguir a la siguiente verificación
0004f0 3081                      	CPI R24, 1        // żR24 es 1?
0004f1 f041                      	BREQ MESUNO // Si ambos son 1, saltar a 30dias
0004f2 3082                      	CPI R24, 2       // żR24 es 1?
0004f3 f011                      	BREQ MESZERO
                                 
                                 	//Verificar condiciones para saltar a 28dias
                                 	// (Como el reloj no cuenta ańos no voy a tomaren cuenta los ańos con 29 dias)
                                 	VERIFICAR_28:
0004f4 3082                      	CPI R24, 2        // żR24 es 2 (febrero)?
0004f5 f041                      	BREQ MESDOS
                                 
                                 
                                 	MESZERO:
0004f6 27cc                      		CLR R28
0004f7 93c0 0110                 		STS	Mes, R28
0004f9 c007                      		RJMP LOGMESFIN
                                 	MESUNO:
0004fa e0c1                      		LDI R28, 1
0004fb 93c0 0110                 		STS	Mes, R28
0004fd c003                      		RJMP LOGMESFIN
                                 	MESDOS:
0004fe e0c2                      		LDI R28, 2
0004ff 93c0 0110                 		STS	Mes, R28
                                 	LOGMESFIN:
000501 9508                      		RET
                                 //---------------------------------------------------------------otra variable  para la logica de los meses
                                 // Mess (0) 0-9 (1) 10-12
                                 MESLOG2:
000502 30a1                      	CPI R26, 1
000503 f020                      	BRLO MESS0
                                 MESS1:
000504 e0c1                      	LDI R28, 1
000505 93c0 0111                 	STS	Mess, R28
000507 c003                      	RJMP MESSLOG2FIN
                                 MESS0:
000508 27cc                      	CLR R28
000509 93c0 0111                 	STS	Mess, R28
                                 
                                 MESSLOG2FIN: 
00050b 9508                      	RET
                                 
                                 //------correcion en la cuenta de dias
                                 CEROCERO:
00050c 3060                      	CPI R22, 0          // Compara R22 con 0
00050d f419                      	BRNE no_cero        
00050e 3020                      	CPI R18, 0       //  R18 con 0   
00050f f409                      	BRNE no_cero        
                                 	// Si llegamos aquí, AMBOS son 0
000510 e021                      	LDI R18, 1          // Cargar 1 en R18
                                 	no_cero:
000511 9508                      	RET
                                 
                                 //--------------------------------------------------------------------------------------------------------INTERRUPCIONES
                                 
                                 // Rutina de interrupci?n del Timer1 - Modo COMPARE MATCH
                                 // Se encarga de contar los segundos
                                 TIMER1_COMPA:      
000512 930f                          PUSH R16
000513 b70f                          IN R16, SREG
000514 930f                          PUSH R16
                                 
                                 
000515 9513                          INC R17                 // Incrementar contador de ciclos
000516 9a1d                      	SBI PINB, PINB5			// titila cada que pasa un seg
                                 
000517 910f                      	POP R16      
000518 bf0f                      	OUT SREG, R16 
000519 910f                      	POP R16     
00051a 9518                      	RETI
                                 
                                 // Rutina de interrupcion del PORTB
                                 // La logica de los botones
                                 INTBOTONES:
00051b 930f                      	PUSH R16
00051c b70f                      	IN R16, SREG
00051d 930f                      	PUSH R16	
00051e 931f                      	PUSH R17
                                 	
00051f b113                      	IN	R17, PINB			 // Leer estado de los botones
000520 9310 0108                 	STS	Botonespressint, R17 // Guardar en variable de interrupción
                                 	//guarda el estado pasado de los botones
000522 9100 0108                 	LDS R16, Botonespressint
000524 9300 0109                     STS Botonespresspasado, R16
                                 	
000526 e608                      	LDI R16, 104     // 10ms 
                                 DELAY_10MS_LOOP1:
000527 ef1f                          LDI R17, 255     // Loop interno
                                 DELAY_10MS_LOOP2:
000528 951a                          DEC R17
000529 f7f1                          BRNE DELAY_10MS_LOOP2
00052a 950a                          DEC R16
00052b f7d9                          BRNE DELAY_10MS_LOOP1
                                 	
00052c b113                      	IN	R17, PINB			 // Leer estado de los botones
00052d 9310 0108                 	STS	Botonespressint, R17 // Guardar en variable de interrupción
00052f 9100 0108                 	LDS R16, Botonespressint
000531 9300 010a                     STS Botonespresspasado2, R16
                                 
                                 	// Comparar con el valor pasado	
000533 9100 0109                 	LDS R16, Botonespresspasado
000535 9110 010a                 	LDS R17, Botonespresspasado2
                                 
000537 1701                          CP R16, R17            // Comparara el estado pasado con el presente
000538 f529                          BRNE FINBOTONES            // Si son diferentes, salir
                                 	
000539 2f30                      	MOV R19, R16   // se guardan los verdaderos valores del boton
                                 	
                                 // Guardar bit PB0
00053a fb30                      BST R19, 0          // Store bit from register T flag (PB0)
00053b f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
00053c 93c0 0112                 STS PBceroB, R28    // Store R28 en variable PBceroB
                                 
                                 // Guardar bit PB1
00053e fb31                      BST R19, 1          // Store bit from register T flag (PB1)
00053f f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
000540 93c0 0113                 STS PBunoB, R28     // Store R28 en variable PBunoB
                                 
                                 // Guardar bit PB2
000542 fb32                      BST R19, 2          // Store bit from register T flag (PB2)
000543 f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
000544 93c0 0114                 STS PBdosB, R28     // Store R28 en variable PBdosB
                                 
                                 // Guardar bit PB3
000546 fb33                      BST R19, 3          // Store bit from register T flag (PB3)
000547 f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
000548 93c0 0115                 STS PBtresB, R28    // Store R28 en variable PBtresB
                                 
                                 // Cargar las variables en R28 y evaluar con SBRC
00054a 91c0 0112                 LDS R28, PBceroB    // Cargar PBceroB en R28
00054c ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
00054d 940e 0563                 CALL boton_PB0
                                 
00054f 91c0 0113                 LDS R28, PBunoB     // Cargar PBunoB en R28
000551 ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
000552 940e 0565                 CALL boton_PB1
                                 
000554 91c0 0114                 LDS R28, PBdosB     // Cargar PBdosB en R28
000556 ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
000557 940e 056e                 CALL boton_PB2
                                 
000559 91c0 0115                 LDS R28, PBtresB    // Cargar PBtresB en R28
00055b ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
00055c 940e 0579                 CALL boton_PB3
                                 
                                 	FINBOTONES:
                                 
00055e 911f                      	POP R17
00055f 910f                      	POP R16
000560 bf0f                      	OUT SREG, R16
000561 910f                      	POP R16
000562 9518                      	RETI
                                 
                                 boton_PB0://----------------------------
                                 	
000563 9543                      	INC R20       //Cambia de modo
                                     
000564 9508                      	RET
                                 
                                 boton_PB1: //----------------------------
                                 	// selecciona el display
000565 9100 010b                 	LDS R16, Selectordisp
000567 9503                      	INC R16
000568 3004                      	CPI R16, 4
000569 f008                      	BRLO SDOVER
00056a 2700                      	CLR R16
                                 SDOVER:
00056b 9300 010b                 	STS Selectordisp, R16
00056d 9508                      	RET
                                 
                                 boton_PB2: //----------------------------
                                 	
00056e 3042                      	CPI R20, 2
00056f f019                          BREQ ACTIVOPB2
                                     
000570 3043                          CPI R20, 3
000571 f009                          BREQ ACTIVOPB2
                                 
000572 c005                      	RJMP boton_PB2fin
                                 ACTIVOPB2:
000573 93cf                      	PUSH R28
000574 e0c1                      	LDI R28, 1
000575 93c0 010c                 	STS Configmas, R28
000577 91cf                      	POP R28
                                 boton_PB2fin:
                                 
000578 9508                      	RET
                                 
                                 boton_PB3: //----------------------------
000579 3042                      	CPI R20, 2
00057a f019                          BREQ ACTIVOPB3
                                     
00057b 3043                          CPI R20, 3
00057c f009                          BREQ ACTIVOPB3
                                 
00057d c005                      	RJMP boton_PB3fin
                                 
                                 ACTIVOPB3:
00057e 93cf                      	PUSH R28
00057f e0c1                      	LDI R28, 1
000580 93c0 010d                 	STS Configmen, R28
000582 91cf                      	POP R28
                                 
                                 boton_PB3fin:
