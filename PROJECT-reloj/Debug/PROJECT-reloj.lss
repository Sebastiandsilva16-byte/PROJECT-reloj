                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 // Creado: 16/02/2026
                                 // Autor : Sebastian Da Silva
                                 // Descripcion:Reloj proyecto
                                 
                                 .include "M328PDEF.inc"
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 .dseg
                                 .org  SRAM_START
                                 .dseg
                                 	.org 0x0100           
000100                           	unidadesMIN:			.byte 1
000101                           	decenasMIN:				.byte 1
000102                           	unidadesHOR:			.byte 1
000103                           	decenasHOR:				.byte 1
000104                           	unidadesDIA:			.byte 1
000105                           	decenasDIA:				.byte 1
000106                           	unidadesMES:			.byte 1
000107                           	decenasMES:				.byte 1
000108                           	Botonespressint:		.byte 1
000109                           	Botonespresspasado:     .byte 1
00010a                           	Botonespresspasado2:    .byte 1
00010b                           	Selectordisp:			.byte 1
00010c                           	Configmas:				.byte 1
00010d                           	Configmen:				.byte 1
00010e                           	TMPactual:				.byte 1
00010f                           	TMPalarma:				.byte 1
000110                           	Mes:					.byte 1
                                 	
                                 .cseg
                                 .org 0x0000
000000 c033                          RJMP SETUP
                                 .org 0x0008
000008 c21c                      	RJMP INTBOTONES //interrpciones de botones portB
                                 .org 0x0016         
000016 c205                          RJMP TIMER1_COMPA	// Vector de interrupción para TIMER1_COMPA 
                                 
                                 
                                 
                                 .org 0x0034
                                 
                                 SETUP:
                                     // Configuraci?n de la pila
000034 ef0f                          LDI     R16, LOW(RAMEND)
000035 bf0d                          OUT     SPL, R16
000036 e008                          LDI     R16, HIGH(RAMEND)
000037 bf0e                          OUT     SPH, R16
                                 		
                                 // ------------------------------------
                                 	
                                 //input botones (pullup)
000038 9820                      	CBI DDRB, DDB0
000039 9a28                      	SBI PORTB, PORTB0
00003a 9821                      	CBI DDRB, DDB1
00003b 9a29                      	SBI PORTB, PORTB1
00003c 9822                      	CBI DDRB, DDB2
00003d 9a2a                      	SBI PORTB, PORTB2
00003e 9823                      	CBI DDRB, DDB3
00003f 9a2b                      	SBI PORTB, PORTB3
                                 // Salidas LEDs (PC0-PC5) y (PD3) (apagados) (7 segmentos)
000040 9a38                      	SBI DDRC, DDC0    // PC0 salida
000041 9840                          CBI PORTC, PORTC0
000042 9a39                      	SBI DDRC, DDC1    // PC1 salida
000043 9841                          CBI PORTC, PORTC1
000044 9a3a                      	SBI DDRC, DDC2    // PC2 salida
000045 9842                          CBI PORTC, PORTC2
000046 9a3b                      	SBI DDRC, DDC3    // PC3 salida
000047 9843                          CBI PORTC, PORTC3
000048 9a3c                      	SBI DDRC, DDC4    // PC4 salida
000049 9844                          CBI PORTC, PORTC4
00004a 9a3d                      	SBI DDRC, DDC5    // PC5 salida
00004b 9845                          CBI PORTC, PORTC5
00004c 9a52                      	SBI DDRD, DDD2    // PD2 Salida
00004d 985a                          CBI PORTD, PORTD2 
                                 	// Salidas para habilitar que display actualizar (PD3-PD6)
00004e 9a53                      	SBI DDRD, DDD3    // PD3 Salida
00004f 985b                          CBI PORTD, PORTD3 
000050 9a54                      	SBI DDRD, DDD4    // PD4 Salida
000051 985c                          CBI PORTD, PORTD4
000052 9a55                      	SBI DDRD, DDD5    // PD5 Salida
000053 985d                          CBI PORTD, PORTD5 
000054 9a56                      	SBI DDRD, DDD6    // PD6 Salida
000055 985e                          CBI PORTD, PORTD6  
                                 	//LEDS ":"
000056 9a25                      	SBI DDRB, DDB5    // PB5 salida
000057 982d                          CBI PORTB, PORTB5
                                 	// LED MODO
000058 9a57                      	SBI DDRD, DDD7    // PD7 salida
000059 985f                          CBI PORTD, PORTD7
                                 	// Configuración Timer1 para 1 minuto en modo CTC ----------------------------------------------------------------------------------
                                 
                                 
                                 	// Configurar modo CTC (WGM12=1) y prescaler 1024 (CS12=1, CS10=1) 
00005a e00d                      	LDI R16, (1 << WGM12) | (1 << CS12) | (0 << CS11) | (1 << CS10)
00005b 9300 0081                 	STS TCCR1B, R16
                                 
                                 	// Cargar OCR1A (para 16 MHz) 1E83 (medio sec)  (00FF) (pruebas)
                                 	
00005d e000                      	LDI R16, 0x00
00005e 9300 0089                 	STS OCR1AH, R16
000060 e001                      	LDI R16, 0x01
000061 9300 0088                 	STS OCR1AL, R16
                                 
                                 
                                 	// Inicializar TCNT1 a 0
000063 2700                      	CLR R16
000064 9300 0085                 	STS TCNT1H, R16
000066 9300 0084                 	STS TCNT1L, R16
                                 
000068 e002                      	LDI R16, (1 << OCIE1A)
000069 9300 006f                     STS TIMSK1, R16
                                 
                                 		
                                 	// Habilita interrupciones del puertoB --------------------------------
00006b e001                      	LDI r16, (1 << PCIE0)
00006c 9300 0068                 	STS PCICR, r16
                                 	// Botones PB0 -> PB3
00006e e00f                      	LDI r16, (1 << PCINT0) | (1 << PCINT1) | (1 << PCINT2) | (1 << PCINT3)
00006f 9300 006b                 	STS PCMSK0, r16
                                 
                                 
                                 	// INICIALIZAR VARIABLES EN SRAM
000071 e000                          LDI R16, 0
                                 
000072 e001                          LDI R16, 1              // Día y mes empieza en 1
000073 9300 0104                     STS unidadesDIA, R16
000075 9300 0106                     STS unidadesMES, R16
000077 e000                          LDI R16, 0
000078 9300 0108                     STS Botonespressint, R16
00007a 9300 0109                     STS Botonespresspasado, R16
00007c 9300 0100                 	STS unidadesMIN, R16
00007e 9300 0101                     STS decenasMIN, R16
000080 9300 0102                     STS unidadesHOR, R16
000082 9300 0103                     STS decenasHOR, R16
000084 9300 0107                 	STS decenasMES, R16
000086 9300 0105                 	STS decenasDIA, R16
                                 
                                 
                                     // Inicializar registros
000088 2700                          CLR R16		// HORAMIN (0) / (MESDIA(1) 
000089 2711                          CLR R17		// Contador de segundos
00008a 2722                          CLR R18		// Cuenta unidades Minutos	 // y de DIAS
00008b 2733                      	CLR R19		// Estado real de los botones
00008c 2744                      	CLR R20		// Modo
00008d 2755                          CLR R21		// Seleciona Display
00008e 2766                      	CLR R22		// Cuenta Decenas Minutos	 // y de DIAS
00008f 2777                      	CLR R23		// Valor a buscar en el .db
000090 2788                      	CLR R24		// Cuenta HORAS			     // y MES
000091 2799                      	CLR R25		// Agarra los valores de R23 Para Actualizar el display
000092 27aa                      	CLR R26		// Decenas de HORAS		     // y MES
000093 27bb                      	CLR R27		// Carry
000094 27cc                      	CLR R28		// VARX (solo la llamo para comparaciones no guarda nada)
000095 27dd                      	CLR R29		// VARX 2
000096 27ee                      	CLR R30		// Para Z low
000097 27ff                      	CLR R31		// Para Z high
                                 
000098 9478                          SEI        // Habilitar interrupciones globales
                                 
                                 //------------------------------------------------------------------------------------- ACABA CONFIG----------------------------------------------------------------------------------------
                                 
                                 MAIN_LOOP:
000099 940e 009e                 	CALL MODO 
00009b 940e 013f                 	CALL DISPF
00009d cffb                      	RJMP MAIN_LOOP
                                 
                                 MODO:   //-------------------------------------------------------------------------------------------MODO SEL
00009e 3040                          CPI R20, 0  // horas y minutos
00009f f059                          BREQ MODO0
                                     
0000a0 3041                          CPI R20, 1 // dias y meses
0000a1 f071                          BREQ MODO1
                                     
0000a2 3042                          CPI R20, 2  // config de 0
0000a3 f089                          BREQ MODO2
                                     
0000a4 3043                          CPI R20, 3 // config de 2
0000a5 f0a9                          BREQ MODO3
                                     
0000a6 3044                          CPI R20, 4 // config alarma
0000a7 f0c9                          BREQ MODO4
                                     
0000a8 3045                          CPI R20, 5 // set/reset alarma
0000a9 f0c9                          BREQ MODO5
                                 
0000aa 2744                      	CLR R20  //(reinicia la cuenta de modos) y sigue al modo0
                                 
                                 
                                 // PORTD7 Apagado  = Hora Min / Encendido = Mes / Dia
                                 // PORTB5 (puntos) = Parpadeando = tiempo corre / encendido = config
                                 
                                 // --------------------------------------------------------------------------------------------MODOS 
                                 MODO0: //HORAS / MINUTOS
                                 // llama la funcion que cuenta el tiempo
                                 // y asigna r16 para que se muestre HH : MM
                                 // des activa el led naranja para indicar HH:MM
0000ab 2700                      	CLR R16
0000ac 985f                      	CBI PORTD, PORTD7
0000ad 940e 018a                     CALL TIEMPO
0000af c015                          RJMP FIN_COMPARAR
                                 
                                 MODO1: //DIA / MES
                                 // asigna r16 para que se muestre DD : MES
                                 // activa el led naranja para indicar DD:MES
0000b0 e001                      	LDI R16, 1
0000b1 9a5f                      	SBI PORTD, PORTD7
0000b2 940e 018a                     CALL TIEMPO
0000b4 c010                          RJMP FIN_COMPARAR
                                 
                                 MODO2: // CONFIG HM
                                 //	asigna r16 para que se muestre HH : MM
                                 // des activa el led naranja para indicar HH:MM
                                 // Enciende los : para indicar modo config
0000b5 2700                      	CLR R16
0000b6 985f                      	CBI PORTD, PORTD7
0000b7 9a2d                      	SBI PORTB, PORTB5
0000b8 c00c                          RJMP FIN_COMPARAR
0000b9 940e 00f3                 	CALL CONFIGRELOJ
                                 
                                 MODO3: // CONGIG MD
                                 // asigna r16 para que se muestre DD : MES
                                 // activa el led naranja para indicar DD:MES
                                 // Enciende los : para indicar modo config
0000bb e001                      	LDI R16, 1
0000bc 9a2d                      	SBI PORTB, PORTB5
0000bd 9a5f                      	SBI PORTD, PORTD7
0000be 940e 00f3                 	CALL CONFIGRELOJ
0000c0 c004                          RJMP FIN_COMPARAR
                                 
                                 MODO4: // CONFIG ALARMA
                                 //	asigna r16 para que se muestre HH : MM
0000c1 2700                      	CLR R16
0000c2 c002                          RJMP FIN_COMPARAR
                                 
                                 MODO5: // APAGAR ALARMA
                                  //	asigna r16 para que se muestre HH : MM
0000c3 2700                      	CLR R16
0000c4 c000                          RJMP FIN_COMPARAR
                                 
                                 FIN_COMPARAR:
0000c5 9508                          RET
                                 
                                 //--------------------------------------------------------------------------LOAD y SAVE 
                                 // para reducir espacio en el codigo
                                 LOADHM:
0000c6 9120 0100                 	LDS R18, unidadesMIN    // Cargar Unidades de Minuto
0000c8 9160 0101                     LDS R22, decenasMIN     // Cargar Decenas de Minuto
0000ca 9180 0102                     LDS R24, unidadesHOR    // Cargar Unidades de Hora
0000cc 91a0 0103                     LDS R26, decenasHOR     // Cargar Decenas de Hora
0000ce 9508                      	RET
                                 LOADDM:
0000cf 9120 0104                 	LDS R18, unidadesDIA    // Cargar Unidades de DIA
0000d1 9160 0105                     LDS R22, decenasDIA     // Cargar Decenas de DIA
0000d3 9180 0106                     LDS R24, unidadesMES    // Cargar Unidades de MES
0000d5 91a0 0107                     LDS R26, decenasMES     // Cargar Decenas de MES
0000d7 9508                      	RET
                                 //invertido para el display	
                                 LOADDMINV:
0000d8 9180 0104                 	LDS R24, unidadesDIA    // Cargar Unidades de DIA
0000da 91a0 0105                     LDS R26, decenasDIA     // Cargar Decenas de DIA
0000dc 9120 0106                     LDS R18, unidadesMES    // Cargar Unidades de MES
0000de 9160 0107                     LDS R22, decenasMES     // Cargar Decenas de MES
0000e0 9508                      	RET
                                 SAVEHM:
0000e1 9320 0100                 	STS unidadesMIN, R18    // Guardar Unidades de Minuto
0000e3 9360 0101                     STS decenasMIN, R22     // Guardar Decenas de Minuto
0000e5 9380 0102                     STS unidadesHOR, R24    // Guardar Unidades de Hora
0000e7 93a0 0103                     STS decenasHOR, R26     // Guardar Decenas de Hora
0000e9 9508                      	RET
                                 SAVEDM:
0000ea 9320 0104                 	STS unidadesDIA, R18    // Guardar Unidades de DIA
0000ec 9360 0105                     STS decenasDIA, R22     // Guardar Decenas de DIA
0000ee 9380 0106                     STS unidadesMES, R24    // Guardar Unidades de MES
0000f0 93a0 0107                     STS decenasMES, R26     // Guardar Decenas de MES
0000f2 9508                      	RET
                                 
                                 //--------------------------------------------------------------------------------------CONFIGRELOJ
                                 //Toda la logia para la suma y resta manual del reloj
                                 
                                 CONFIGRELOJ:
                                 //R16 (0) MM:HH (1) DD:MM 
                                 
0000f3 3001                      	CPI R16, 1
0000f4 f011                          BREQ CONFIGMESDIA
                                     
0000f5 3000                          CPI R16, 0
0000f6 f129                          BREQ CONFIGHORAMIN
                                 //Configmen (0) nada (1) restar 
                                 //Configmas (0) nada (1) sumar	
                                 
                                 CONFIGMESDIA:
0000f7 940e 00cf                 	CALL LOADDM	
                                 	//mira si hay que sumar
0000f9 91c0 010c                 	LDS R28, Configmas  
0000fb 30c1                      	CPI R28, 1
0000fc f029                      	BREQ SUMARDM
                                 	//mira si hay que restar
0000fd 91c0 010d                 	LDS R28, Configmen
0000ff 30c1                      	CPI R28, 1
000100 f071                      	BREQ RESTADM
                                 	//si no pasa nada regresa
000101 c03c                      	RJMP CONFIGRELOJFIN
                                 
                                 SUMARDM:  //los modos de suma se pueden aprovechar de la funcion Tiempo asi que solo hago una suma y hago una calls
000102 91c0 010b                 	LDS R28, Selectordisp
                                 
000104 30c0                      	CPI R28, 0 // Compara con 0
000105 f031                          BREQ SuniDmes
000106 30c1                          CPI R28, 1 // Compara con 1
000107 f029                          BREQ SdecDmes
000108 30c2                          CPI R28, 2 // Compara con 2
000109 f021                          BREQ SuniDdia 
00010a 30c3                          CPI R28, 3 // Compara con 3
00010b f019                          BREQ SdecDdia
                                 
                                 SuniDmes:
00010c c002                      	RJMP RESTADM
                                 SdecDmes:
00010d c001                      	RJMP RESTADM
                                 SuniDdia:
00010e c000                      	RJMP RESTADM
                                 SdecDdia:
                                 
                                 RESTADM:
00010f 91c0 010b                 	LDS R28, Selectordisp
                                 
000111 30c0                      	CPI R28, 0 // Compara con 0
000112 f031                          BREQ RuniDmes
000113 30c1                          CPI R28, 1 // Compara con 1
000114 f021                          BREQ RdecDmes
000115 30c2                          CPI R28, 2 // Compara con 2
000116 f011                          BREQ RuniDdia
000117 30c3                          CPI R28, 3 // Compara con 3
000118 f001                          BREQ RdecDdia
                                 
                                 RuniDmes:
                                 RdecDmes:
                                 RuniDdia:
                                 RdecDdia:
                                 	
                                 
                                 
000119 940e 00ea                 	CALL SAVEDM
00011b c022                      	RJMP CONFIGRELOJFIN
                                 CONFIGHORAMIN:
00011c 940e 00c6                 	CALL LOADHM	
                                 
                                 	//mira si hay que sumar
00011e 91c0 010c                 	LDS R28, Configmas  
000120 30c1                      	CPI R28, 1
000121 f029                      	BREQ SUMARHM
                                 	//mira si hay que restar
000122 91c0 010d                 	LDS R28, Configmen
000124 30c1                      	CPI R28, 1
000125 f059                      	BREQ RESTAHM
                                 	//si no pasa nada regresa
000126 c017                      	RJMP CONFIGRELOJFIN
                                 
                                 SUMARHM:
000127 91c0 010b                 	LDS R28, Selectordisp
                                 
000129 30c0                      	CPI R28, 0 // Compara con 0
00012a f031                          BREQ SuniDmin
00012b 30c1                          CPI R28, 1 // Compara con 1
00012c f021                          BREQ SdecDmin
00012d 30c2                          CPI R28, 2 // Compara con 2
00012e f011                          BREQ SuniDhora
00012f 30c3                          CPI R28, 3 // Compara con 3
000130 f001                          BREQ SdecDhora
                                 
                                 SuniDmin:
                                 SdecDmin:
                                 SuniDhora:
                                 SdecDhora:
                                 
                                 RESTAHM:
000131 91c0 010b                 	LDS R28, Selectordisp
                                 	
000133 30c0                      	CPI R28, 0 // Compara con 0
000134 f031                          BREQ RuniDmin
000135 30c1                          CPI R28, 1 // Compara con 1
000136 f021                          BREQ RdecDmin
000137 30c2                          CPI R28, 2 // Compara con 2
000138 f011                          BREQ RuniDhora
000139 30c3                          CPI R28, 3 // Compara con 3
00013a f001                          BREQ RdecDhora
                                 
                                 RuniDmin:
                                 RdecDmin:
                                 RuniDhora:
                                 RdecDhora:
                                 
00013b 940e 00e1                 	CALL SAVEHM
00013d c000                      	RJMP CONFIGRELOJFIN
                                 CONFIGRELOJFIN:
                                 
00013e 9508                      	RET
                                 
                                 
                                 //----------------------------------------------------------------------------------------------DISPF
                                 // toda la logica para el funcionamiento de los displays
                                 DISPF:
                                 
00013f 3001                      	CPI R16, 1
000140 f011                          BREQ MESDIA
                                     
000141 3000                          CPI R16, 0
000142 f019                          BREQ HORAMIN
                                 
                                 MESDIA:
000143 940e 00d8                 	CALL LOADDMINV
000145 c002                      	RJMP DISPSELCALC
                                 HORAMIN:
000146 940e 00c6                 	CALL LOADHM
                                 
                                 DISPSELCALC:
                                 
000148 3054                          CPI R21, 4
000149 f010                      	BRLO DISPSEL     // Si R21 < 4, está bien
00014a 2755                          CLR R21          // Si R21 >= 4, resetea a 0    
00014b 9508                      	RET
                                 
                                 DISPSEL:
00014c 940e 0150                 	CALL DISPLAYSEL
00014e 9553                      	INC R21 //Va haciendo la cuenta para actulizar los contadores individualmente
00014f 9508                          RET
                                 
                                 DISPLAYSEL:
                                 
000150 3050                          CPI R21, 0 // Compara con 0
000151 f031                          BREQ DISP0 // Salta a DISP0 si R21 = 0
000152 3051                          CPI R21, 1 // Compara con 1
000153 f051                          BREQ DISP1 // Salta a DISP1 si R21 = 1
000154 3052                          CPI R21, 2 // Compara con 2
000155 f071                          BREQ DISP2 // Salta a DISP2 si R21 = 2
000156 3053                          CPI R21, 3 // Compara con 3
000157 f091                          BREQ DISP3 // Salta a DISP3 si R21 = 3
                                 	//nunca deberia pasar sin saltar
                                 
                                 DISP0:
000158 985c                          CBI PORTD, 4    // Apaga PD4
000159 985d                          CBI PORTD, 5    // Apaga PD5
00015a 985e                          CBI PORTD, 6    // Apaga PD6
00015b 9a5b                          SBI PORTD, 3    // Enciende PD3 (DISP0)
00015c 2f72                      	MOV R23, R18	// Cuenta de Unidades S a R23
00015d c012                      	RJMP DISPLAY
                                 
                                 DISP1:
00015e 985b                          CBI PORTD, 3    // Apaga PD3
00015f 985d                          CBI PORTD, 5    // Apaga PD5
000160 985e                          CBI PORTD, 6    // Apaga PD6
000161 9a5c                          SBI PORTD, 4    // Enciende PD4 (DISP1)
000162 2f76                      	MOV R23, R22	// Cuenta de Decenas S a R23
000163 c00c                          RJMP DISPLAY
                                 
                                 DISP2:
000164 985b                          CBI PORTD, 3    // Apaga PD3
000165 985c                          CBI PORTD, 4    // Apaga PD4
000166 985e                          CBI PORTD, 6    // Apaga PD6
000167 9a5d                          SBI PORTD, 5    // Enciende PD5 (DISP2)
000168 2f78                      	MOV R23, R24	// Cuenta de Unidades S a R23
000169 c006                          RJMP DISPLAY
                                 
                                 DISP3:
00016a 985b                          CBI PORTD, 3    // Apaga PD3
00016b 985c                          CBI PORTD, 4    // Apaga PD4
00016c 985d                          CBI PORTD, 5    // Apaga PD5
00016d 9a5e                          SBI PORTD, 6    // Enciende PD6 (DISP3)
00016e 2f7a                      	MOV R23, R26	// Cuenta de Decenas S a R23
00016f c000                          RJMP DISPLAY
                                 
                                 DISPLAY:
000170 934f                      	PUSH R20
000171 93ff                      	PUSH ZH
000172 93ef                          PUSH ZL
                                 
000173 e0f4                          LDI ZH, HIGH(disp7seg << 1)
000174 eeec                          LDI ZL, LOW(disp7seg << 1)
                                 
                                 	// busca los valores para el 7 segmentos
000175 0f77                      	LSL R23		//mueve los bits a la iz (multiplica por 2)
000176 0fe7                      	ADD ZL, R23
000177 e040                      	LDI R20, 0
000178 1ff4                      	ADC ZH, R20
000179 9174                      	LPM R23, Z
                                 
00017a 91ef                      	POP ZL
00017b 91ff                          POP ZH
00017c 914f                      	POP R20
                                 
                                 	//Actualiza todo el portC (6 segmentos)
00017d 2f97                      	MOV R25, R23
00017e b998                      	OUT PORTC, R25  
                                 	//Actualiza el ultimo segmento
00017f fd96                      	SBRC R25, 6
000180 9a5a                          SBI PORTD, PORTD2
000181 ff96                          SBRS R25, 6
000182 985a                          CBI PORTD, PORTD2
                                 
                                 	//Limpia para que no afecte los otros diplays
000183 2799                      	CLR R25
000184 b998                      	OUT PORTC, R25  
                                 	//Actualiza el ultimo segmento
000185 fd96                      	SBRC R25, 6
000186 9a5a                          SBI PORTD, PORTD2
000187 ff96                          SBRS R25, 6
000188 985a                          CBI PORTD, PORTD2 
000189 9508                      RET
                                 
                                 
                                 // -----------------------------------------------------------------------------------------------------TIEMPO
                                 // Toda la logica de la cuenta del tiempo
                                 TIEMPO:
                                 	
00018a 940e 00c6                 	CALL LOADHM
                                 	
                                 	// modos con la cuenta interrumpida
00018c 3042                      	CPI R20, 2
00018d f010                          BRLO Sicontar
00018e 2711                      	CLR	R17
00018f c003                      	RJMP Nocontar
                                 	Sicontar:
                                 
000190 3011                      	CPI R17, 1 //segundos (118) (1 para pruebas de dia y mes)
000191 f0c0                          BRLO TIMER_RET
000192 2711                      	CLR R17
                                 
                                 	Nocontar:
                                 
                                 	//Unidades de Minutos
000193 9523                      	INC R18
000194 302a                          CPI R18, 10
000195 f0a0                          BRLO TIMER_RET
000196 2722                      	CLR R18
                                 
000197 9563                      	INC R22			//Decenas de Minutos
000198 3066                      	CPI R22, 6
000199 f080                      	BRLO TIMER_RET
00019a 2766                      	CLR R22
                                 
00019b 9583                      	INC R24			//Unidades de Horas
00019c 30a2                      	CPI R26, 2	
00019d f421                      	BRNE ZEROoDIEZ // revisa que no ha llegado a 20
00019e 3084                      	CPI R24, 4
00019f f050                      	BRLO TIMER_RET
0001a0 2788                      	CLR R24
0001a1 c003                      	RJMP DECENASdeHORAS
                                 ZEROoDIEZ:
0001a2 308a                      	CPI R24, 10
0001a3 f030                      	BRLO TIMER_RET
0001a4 2788                      	CLR R24
                                 
                                 DECENASdeHORAS:
0001a5 95a3                      	INC R26			//Decenas de Horas
0001a6 30a3                      	CPI R26, 3
0001a7 f010                      	BRLO TIMER_RET
0001a8 27aa                      	CLR R26
0001a9 95b3                      	INC R27
                                 
                                 TIMER_RET:
                                 	//Ahora cambio para hacer lo de los dias
0001aa 940e 00e1                 	CALL SAVEHM
0001ac 940e 00cf                 	CALL LOADDM
                                 
                                 	// Verificar carry (ya paso un dia?)
0001ae 30b0                      	CPI R27, 0
0001af f0f1                      	BREQ TEMPORAL	  // Si R27 es 0, (no cambio nada en MES/DIA asi que sale)
0001b0 9523                      	INC R18           // Si R27 está activo, sumar 1 a R18
0001b1 27bb                      	CLR R27
                                 
0001b2 940e 0204                 	CALL LOGDIAS			//para ver como se debe efectuar la suma de dias
                                 
0001b4 91c0 0110                 	LDS R28, Mes
0001b6 30c0                      	CPI R28, 0  // horas y minutos
0001b7 f139                          BREQ TREINTA_Y_UN_DIAS
                                     
0001b8 30c1                          CPI R28, 1
0001b9 f011                          BREQ TREINTA_DIAS
                                     
0001ba 30c2                          CPI R28, 2  
0001bb f099                          BREQ VEINTIOCHO_DIAS
                                 
                                 
                                 TREINTA_DIAS: // Aquí va la lógica para meses de 30 días ----------------------------------------------
0001bc 3063                      	CPI R22, 3
0001bd f029                      	BREQ TREINTA
0001be 302a                      	CPI R18, 10          // Comparar R18 (unidades de día) con 10
0001bf f070                      	BRLO TEMPORAL      
0001c0 2722                      	CLR R18              
0001c1 9563                      	INC R22
0001c2 c006                      	RJMP TREINTAFIN
                                 	TREINTA:
0001c3 3021                      	CPI R18, 1    
0001c4 f1e0                      	BRLO TIMER_RET2      
0001c5 2722                      	CLR R18                    
0001c6 2766                      	CLR R22              
0001c7 9583                      	INC R24 
0001c8 c028                      	RJMP MESLOG
                                 	TREINTAFIN:              // Incrementar decenas de día en 1
0001c9 3064                      	CPI R22, 4          // Comparar R18 (decenas de día) con 4
0001ca f1b0                      	BRLO TIMER_RET2      
0001cb 2766                      	CLR R22              
0001cc 9583                      	INC R24              // Incrementar unidades de mes
0001cd c023                      	RJMP MESLOG //ahora va a ver la logica de los meses
                                 TEMPORAL:
0001ce c022                      	RJMP MESLOG
                                 VEINTIOCHO_DIAS:	// Aquí va la lógica para febrero (28 días)----------------------------------------------------
0001cf 3062                      	CPI R22, 2
0001d0 f029                      	BREQ VEINTE
0001d1 302a                      	CPI R18, 10          // Comparar R18 (unidades de día) con 10
0001d2 f170                      	BRLO TIMER_RET2      
0001d3 2722                      	CLR R18              
0001d4 9563                      	INC R22              // Incrementar decenas de día en 1
0001d5 c004                      	RJMP VEINTEFIN
                                 VEINTE:
0001d6 3029                      	CPI R18, 9          // Comparar R18 (unidades de día) con 9
0001d7 f148                      	BRLO TIMER_RET2      
0001d8 2722                      	CLR R18              
0001d9 9563                      	INC R22              // Incrementar decenas de día en 1
                                 VEINTEFIN:
0001da 3063                      	CPI R22, 3          // Comparar R18 (decenas de día) con 3
0001db f128                      	BRLO TIMER_RET2      
0001dc 2766                      	CLR R22              
0001dd 9583                      	INC R24              // Incrementar unidades de mes
0001de c012                      	RJMP MESLOG //ahora va a ver la logica de los meses
                                 TREINTA_Y_UN_DIAS: // Aquí va la lógica para meses de 31 días -----------------------------------------------------
0001df 3063                      	CPI R22, 3
0001e0 f029                      	BREQ TREINTAUNO
0001e1 302a                      	CPI R18, 10          // Comparar R18 (unidades de día) con 10
0001e2 f0f0                      	BRLO TIMER_RET2      
0001e3 2722                      	CLR R18              
0001e4 9563                      	INC R22              // Incrementar decenas de día en 1
0001e5 c006                      	RJMP TREINTAUNOFIN
                                 TREINTAUNO:
0001e6 3022                      	CPI R18, 2          // Comparar R18 (unidades de día) con 9
0001e7 f0c8                      	BRLO TIMER_RET2      
0001e8 2722                      	CLR R18              
0001e9 2766                      	CLR R22              
0001ea 9583                      	INC R24 
0001eb c005                      	RJMP MESLOG
                                 TREINTAUNOFIN:
0001ec 3064                      	CPI R22, 4          // Comparar R18 (decenas de día) con 3
0001ed f098                      	BRLO TIMER_RET2      
0001ee 2766                      	CLR R22              
0001ef 9583                      	INC R24              // Incrementar unidades de mes
0001f0 c000                      	RJMP MESLOG //ahora va a ver la logica de los meses
                                 	MESLOG:
0001f1 30a1                      	CPI R26, 1
0001f2 f041                      	BREQ MES10
                                 	MESNORMAL:
0001f3 308a                      	CPI R24, 10          // si alcanzan las decenas suma 1
0001f4 f060                      	BRLO TIMER_RET2      
0001f5 2788                      	CLR R24            
0001f6 95a3                      	INC R26              // Incrementar decenas de mes
0001f7 e081                      	LDI R24, 1            
0001f8 2766                      	CLR R22
0001f9 e021                      	LDI R18, 1 
                                 
0001fa c006                      	RJMP TIMER_RET2
                                 
                                 	MES10:
                                 
0001fb 3083                      	CPI R24, 3          // si alcanza 3 reinicia
0001fc f020                      	BRLO TIMER_RET2      
0001fd e081                      	LDI R24, 1            
0001fe 27aa                      	CLR R26   
0001ff 2766                      	CLR R22
000200 e021                      	LDI R18, 1          
                                 
                                 
                                 	TIMER_RET2:
000201 940e 00ea                 	CALL SAVEDM
000203 9508                          RET
                                 
                                 //--------------------------------------------------------------------------------------------------------LOGICA DE DIAS
                                 // Mes-->  (0) 31 dias (1) 30 dias (2) 28 dias
                                 LOGDIAS:
                                 	// Verificar condiciones para saltar a 30dias
000204 3084                      	CPI R24, 4        // żR24 es 4 (abril)?
000205 f071                      	BREQ MESUNO
000206 3086                      	CPI R24, 6        // żR24 es 6 (junio)?
000207 f061                      	BREQ MESUNO
000208 3089                      	CPI R24, 9        // żR24 es 9 (septiembre)?
000209 f051                      	BREQ MESUNO
                                 
                                 	// Verificar si R26=1 y R24=1 (noviembre)
00020a 30a1                      	CPI R26, 1        // żR26 es 1?
00020b f411                      	BRNE VERIFICAR_28 // Si R26 no es 1, seguir a la siguiente verificación
00020c 3081                      	CPI R24, 1        // żR24 es 1?
00020d f031                      	BREQ MESUNO // Si ambos son 1, saltar a 30dias
                                 
                                 	//Verificar condiciones para saltar a 28dias
                                 	// (Como el reloj no cuenta ańos no voy a tomaren cuenta los ańos con 29 dias)
                                 	VERIFICAR_28:
00020e 3082                      	CPI R24, 2        // żR24 es 2 (febrero)?
00020f f041                      	BREQ MESDOS
                                 
                                 
                                 	MESZERO:
000210 27cc                      		CLR R28
000211 93c0 0110                 		STS	Mes, R28
000213 c007                      		RJMP LOGMESFIN
                                 	MESUNO:
000214 e0c1                      		LDI R28, 1
000215 93c0 0110                 		STS	Mes, R28
000217 c003                      		RJMP LOGMESFIN
                                 	MESDOS:
000218 e0c2                      		LDI R28, 2
000219 93c0 0110                 		STS	Mes, R28
                                 	LOGMESFIN:
00021b 9508                      		RET
                                 
                                 
