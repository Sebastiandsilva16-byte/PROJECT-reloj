                                 TREINTA_Y_UN_DIAS: // Aquí va la lógica para meses de 31 días -----------------------------------------------------
0004c3 3063                      	CPI R22, 3
0004c4 f029                      	BREQ TREINTAUNO
0004c5 302a                      	CPI R18, 10          // Comparar R18 (unidades de día) con 10
0004c6 f118                      	BRLO TIMER_RET2      
0004c7 2722                      	CLR R18              
0004c8 9563                      	INC R22              // Incrementar decenas de día en 1
0004c9 c006                      	RJMP TREINTAUNOFIN
                                 TREINTAUNO:
0004ca 3022                      	CPI R18, 2          // Comparar R18 (unidades de día) con 9
0004cb f0f0                      	BRLO TIMER_RET2      
0004cc 2722                      	CLR R18              
0004cd 2766                      	CLR R22              
0004ce 9583                      	INC R24 
0004cf c005                      	RJMP MESLOG
                                 TREINTAUNOFIN:
0004d0 3064                      	CPI R22, 4          // Comparar R18 (decenas de día) con 3
0004d1 f0c0                      	BRLO TIMER_RET2   
0004d2 e021                      	LDI R18, 1    
0004d3 2766                      	CLR R22              
0004d4 9583                      	INC R24              // Incrementar unidades de mes 
                                 MESLOG: //ahora va a ver la logica de los meses
0004d5 940e 0509                 	CALL MESLOG2
                                 	   
0004d7 91c0 0111                 	LDS R28, Mess
0004d9 30c0                      	CPI R28, 0  
0004da f011                          BREQ MESNORMAL
                                     
0004db 30c1                          CPI R28, 1
0004dc f039                          BREQ MES10
                                 		
                                 	MESNORMAL:
0004dd 308a                      	CPI R24, 10          // si alcanzan las decenas suma 1
0004de f058                      	BRLO TIMER_RET2      
0004df 2788                      	CLR R24            
0004e0 95a3                      	INC R26              // Incrementar decenas de mes      
0004e1 2766                      	CLR R22
0004e2 e021                      	LDI R18, 1 
0004e3 c006                      	RJMP TIMER_RET2
                                 
                                 	MES10:
0004e4 3083                      	CPI R24, 3          // si alcanza 3 reinicia
0004e5 f020                      	BRLO TIMER_RET2      
0004e6 e081                      	LDI R24, 1            
0004e7 27aa                      	CLR R26   
0004e8 2766                      	CLR R22
0004e9 e021                      	LDI R18, 1    	 
                                 TIMER_RET2:
0004ea 940e 0513                 	CALL cerocero
0004ec 940e 00f1                 	CALL SAVEDM
0004ee 9508                          RET
                                 
                                 //--------------------------------------------------------------------------------------------------------LOGICA DE DIAS
                                 // Mes-->  (0) 31 dias (1) 30 dias (2) 28 dias
                                 LOGDIAS:
                                 	// Verificar condiciones para saltar a 30dias
0004ef 3084                      	CPI R24, 4        // żR24 es 4 (abril)?
0004f0 f081                      	BREQ MESUNO
0004f1 3086                      	CPI R24, 6        // żR24 es 6 (junio)?
0004f2 f071                      	BREQ MESUNO
0004f3 3089                      	CPI R24, 9        // żR24 es 9 (septiembre)?
0004f4 f061                      	BREQ MESUNO
                                 
                                 	// Verificar si R26=1 y R24=1 (noviembre)
0004f5 30a1                      	CPI R26, 1        // żR26 es 1?
0004f6 f421                      	BRNE VERIFICAR_28 // Si R26 no es 1, seguir a la siguiente verificación
0004f7 3081                      	CPI R24, 1        // żR24 es 1?
0004f8 f041                      	BREQ MESUNO // Si ambos son 1, saltar a 30dias
0004f9 3082                      	CPI R24, 2       // żR24 es 1?
0004fa f011                      	BREQ MESZERO
                                 
                                 	//Verificar condiciones para saltar a 28dias
                                 	// (Como el reloj no cuenta ańos no voy a tomaren cuenta los ańos con 29 dias)
                                 	VERIFICAR_28:
0004fb 3082                      	CPI R24, 2        // żR24 es 2 (febrero)?
0004fc f041                      	BREQ MESDOS
                                 
                                 
                                 	MESZERO:
0004fd 27cc                      		CLR R28
0004fe 93c0 0110                 		STS	Mes, R28
000500 c007                      		RJMP LOGMESFIN
                                 	MESUNO:
000501 e0c1                      		LDI R28, 1
000502 93c0 0110                 		STS	Mes, R28
000504 c003                      		RJMP LOGMESFIN
                                 	MESDOS:
000505 e0c2                      		LDI R28, 2
000506 93c0 0110                 		STS	Mes, R28
                                 	LOGMESFIN:
000508 9508                      		RET
                                 //---------------------------------------------------------------otra variable  para la logica de los meses
                                 // Mess (0) 0-9 (1) 10-12
                                 MESLOG2:
000509 30a1                      	CPI R26, 1
00050a f020                      	BRLO MESS0
                                 MESS1:
00050b e0c1                      	LDI R28, 1
00050c 93c0 0111                 	STS	Mess, R28
00050e c003                      	RJMP MESSLOG2FIN
                                 MESS0:
00050f 27cc                      	CLR R28
000510 93c0 0111                 	STS	Mess, R28
                                 
                                 MESSLOG2FIN: 
000512 9508                      	RET
                                 
                                 //------correcion en la cuenta de dias
                                 CEROCERO:
000513 3060                      	CPI R22, 0          // Compara R22 con 0
000514 f419                      	BRNE no_cero        
000515 3020                      	CPI R18, 0       //  R18 con 0   
000516 f409                      	BRNE no_cero        
                                 	// Si llegamos aquí, AMBOS son 0
000517 e021                      	LDI R18, 1          // Cargar 1 en R18
                                 	no_cero:
000518 9508                      	RET
                                 
