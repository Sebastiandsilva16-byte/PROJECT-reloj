                                 // Rutina de interrupcion del PORTB
                                 // La logica de los botones
                                 INTBOTONES:
00057c 930f                      	PUSH R16
00057d b70f                      	IN R16, SREG
00057e 930f                      	PUSH R16	
00057f 931f                      	PUSH R17
                                 	
000580 b113                      	IN	R17, PINB			 // Leer estado de los botones
000581 9310 0108                 	STS	Botonespressint, R17 // Guardar en variable de interrupción
                                 	//guarda el estado pasado de los botones
000583 9100 0108                 	LDS R16, Botonespressint
000585 9300 0109                     STS Botonespresspasado, R16
                                 	
000587 e608                      	LDI R16, 104     // 10ms 
                                 DELAY_10MS_LOOP1:
000588 ef1f                          LDI R17, 255     // Loop interno
                                 DELAY_10MS_LOOP2:
000589 951a                          DEC R17
00058a f7f1                          BRNE DELAY_10MS_LOOP2
00058b 950a                          DEC R16
00058c f7d9                          BRNE DELAY_10MS_LOOP1
                                 	
00058d b113                      	IN	R17, PINB			 // Leer estado de los botones
00058e 9310 0108                 	STS	Botonespressint, R17 // Guardar en variable de interrupción
000590 9100 0108                 	LDS R16, Botonespressint
000592 9300 010a                     STS Botonespresspasado2, R16
                                 
                                 	// Comparar con el valor pasado	
000594 9100 0109                 	LDS R16, Botonespresspasado
000596 9110 010a                 	LDS R17, Botonespresspasado2
                                 
000598 1701                          CP R16, R17            // Comparara el estado pasado con el presente
000599 f529                          BRNE FINBOTONES            // Si son diferentes, salir
                                 	
00059a 2f30                      	MOV R19, R16   // se guardan los verdaderos valores del boton
                                 	
                                 // Guardar bit PB0
00059b fb30                      BST R19, 0          // Store bit from register T flag (PB0)
00059c f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
00059d 93c0 0112                 STS PBceroB, R28    // Store R28 en variable PBceroB
                                 
                                 // Guardar bit PB1
00059f fb31                      BST R19, 1          // Store bit from register T flag (PB1)
0005a0 f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
0005a1 93c0 0113                 STS PBunoB, R28     // Store R28 en variable PBunoB
                                 
                                 // Guardar bit PB2
0005a3 fb32                      BST R19, 2          // Store bit from register T flag (PB2)
0005a4 f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
0005a5 93c0 0114                 STS PBdosB, R28     // Store R28 en variable PBdosB
                                 
                                 // Guardar bit PB3
0005a7 fb33                      BST R19, 3          // Store bit from register T flag (PB3)
0005a8 f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
0005a9 93c0 0115                 STS PBtresB, R28    // Store R28 en variable PBtresB
                                 
                                 // Cargar las variables en R28 y evaluar con SBRC
0005ab 91c0 0112                 LDS R28, PBceroB    // Cargar PBceroB en R28
0005ad ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
0005ae 940e 05c4                 CALL boton_PB0
                                 
0005b0 91c0 0113                 LDS R28, PBunoB     // Cargar PBunoB en R28
0005b2 ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
0005b3 940e 05c6                 CALL boton_PB1
                                 
0005b5 91c0 0114                 LDS R28, PBdosB     // Cargar PBdosB en R28
0005b7 ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
0005b8 940e 05cf                 CALL boton_PB2
                                 
0005ba 91c0 0115                 LDS R28, PBtresB    // Cargar PBtresB en R28
0005bc ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
0005bd 940e 05dc                 CALL boton_PB3
                                 
                                 	FINBOTONES:
                                 
0005bf 911f                      	POP R17
0005c0 910f                      	POP R16
0005c1 bf0f                      	OUT SREG, R16
0005c2 910f                      	POP R16
0005c3 9518                      	RETI
                                 
