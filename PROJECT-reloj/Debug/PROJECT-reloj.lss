00041e 940e 00d8                 	CALL LOADDMINV
000420 c002                      	RJMP DISPSELCALC
                                 HORAMIN:
000421 940e 00c6                 	CALL LOADHM
                                 
                                 DISPSELCALC:
                                 
000423 3054                          CPI R21, 4
000424 f010                      	BRLO DISPSEL     // Si R21 < 4, está bien
000425 2755                          CLR R21          // Si R21 >= 4, resetea a 0    
000426 9508                      	RET
                                 
                                 DISPSEL:
000427 940e 042b                 	CALL DISPLAYSEL
000429 9553                      	INC R21 //Va haciendo la cuenta para actulizar los contadores individualmente
00042a 9508                          RET
                                 
                                 DISPLAYSEL:
                                 
00042b 3050                          CPI R21, 0 // Compara con 0
00042c f031                          BREQ DISP0 // Salta a DISP0 si R21 = 0
00042d 3051                          CPI R21, 1 // Compara con 1
00042e f051                          BREQ DISP1 // Salta a DISP1 si R21 = 1
00042f 3052                          CPI R21, 2 // Compara con 2
000430 f071                          BREQ DISP2 // Salta a DISP2 si R21 = 2
000431 3053                          CPI R21, 3 // Compara con 3
000432 f091                          BREQ DISP3 // Salta a DISP3 si R21 = 3
                                 	//nunca deberia pasar sin saltar
                                 
                                 DISP0:
000433 985c                          CBI PORTD, 4    // Apaga PD4
000434 985d                          CBI PORTD, 5    // Apaga PD5
000435 985e                          CBI PORTD, 6    // Apaga PD6
000436 9a5b                          SBI PORTD, 3    // Enciende PD3 (DISP0)
000437 2f72                      	MOV R23, R18	// Cuenta de Unidades S a R23
000438 c012                      	RJMP DISPLAY
                                 
                                 DISP1:
000439 985b                          CBI PORTD, 3    // Apaga PD3
00043a 985d                          CBI PORTD, 5    // Apaga PD5
00043b 985e                          CBI PORTD, 6    // Apaga PD6
00043c 9a5c                          SBI PORTD, 4    // Enciende PD4 (DISP1)
00043d 2f76                      	MOV R23, R22	// Cuenta de Decenas S a R23
00043e c00c                          RJMP DISPLAY
                                 
                                 DISP2:
00043f 985b                          CBI PORTD, 3    // Apaga PD3
000440 985c                          CBI PORTD, 4    // Apaga PD4
000441 985e                          CBI PORTD, 6    // Apaga PD6
000442 9a5d                          SBI PORTD, 5    // Enciende PD5 (DISP2)
000443 2f78                      	MOV R23, R24	// Cuenta de Unidades S a R23
000444 c006                          RJMP DISPLAY
                                 
                                 DISP3:
000445 985b                          CBI PORTD, 3    // Apaga PD3
000446 985c                          CBI PORTD, 4    // Apaga PD4
000447 985d                          CBI PORTD, 5    // Apaga PD5
000448 9a5e                          SBI PORTD, 6    // Enciende PD6 (DISP3)
000449 2f7a                      	MOV R23, R26	// Cuenta de Decenas S a R23
00044a c000                          RJMP DISPLAY
                                 
                                 DISPLAY:
00044b 934f                      	PUSH R20
00044c 93ff                      	PUSH ZH
00044d 93ef                          PUSH ZL
                                 
00044e e0fb                          LDI ZH, HIGH(disp7seg << 1)
00044f e0e8                          LDI ZL, LOW(disp7seg << 1)
                                 
                                 	// busca los valores para el 7 segmentos
000450 0f77                      	LSL R23		//mueve los bits a la iz (multiplica por 2)
000451 0fe7                      	ADD ZL, R23
000452 e040                      	LDI R20, 0
000453 1ff4                      	ADC ZH, R20
000454 9174                      	LPM R23, Z
                                 
000455 91ef                      	POP ZL
000456 91ff                          POP ZH
000457 914f                      	POP R20
                                 
                                 	//Actualiza todo el portC (6 segmentos)
000458 2f97                      	MOV R25, R23
000459 b998                      	OUT PORTC, R25  
                                 	//Actualiza el ultimo segmento
00045a fd96                      	SBRC R25, 6
00045b 9a5a                          SBI PORTD, PORTD2
00045c ff96                          SBRS R25, 6
00045d 985a                          CBI PORTD, PORTD2
                                 
                                 	//Limpia para que no afecte los otros diplays
00045e 2799                      	CLR R25
00045f b998                      	OUT PORTC, R25  
                                 	//Actualiza el ultimo segmento
000460 fd96                      	SBRC R25, 6
000461 9a5a                          SBI PORTD, PORTD2
000462 ff96                          SBRS R25, 6
000463 985a                          CBI PORTD, PORTD2 
000464 9508                      RET
                                 
                                 
