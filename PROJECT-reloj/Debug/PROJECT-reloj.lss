                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 // Creado: 16/02/2026
                                 // Autor : Sebastian Da Silva
                                 // Descripcion:Reloj proyecto
                                 
                                 .include "M328PDEF.inc"
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 .dseg
                                 .org  SRAM_START
                                 .dseg
                                 	.org 0x0100           
000100                           	unidadesMIN:			.byte 1
000101                           	decenasMIN:				.byte 1
000102                           	unidadesHOR:			.byte 1
000103                           	decenasHOR:				.byte 1
000104                           	unidadesDIA:			.byte 1
000105                           	decenasDIA:				.byte 1
000106                           	unidadesMES:			.byte 1
000107                           	decenasMES:				.byte 1
000108                           	Botonespressint:		.byte 1
000109                           	Botonespresspasado:     .byte 1
00010a                           	Botonespresspasado2:    .byte 1
00010b                           	Selectordisp:			.byte 1
00010c                           	Configmas:				.byte 1
00010d                           	Configmen:				.byte 1
00010e                           	TMPactual:				.byte 1
00010f                           	TMPalarma:				.byte 1
000110                           	Mes:					.byte 1
000111                           	Mess:					.byte 1
000112                           	PBceroB:				.byte 1
000113                           	PBunoB:					.byte 1
000114                           	PBdosB:					.byte 1
000115                           	PBtresB:				.byte 1
000116                           	alarmaUM:				.byte 1
000117                           	alarmaDM:				.byte 1
000118                           	alarmaUH:				.byte 1
000119                           	alarmaDH:				.byte 1
                                 	
                                 .cseg
                                 .org 0x0000
000000 c033                          RJMP SETUP
                                 .org 0x0008
000008 c573                      	RJMP INTBOTONES //interrpciones de botones portB
                                 .org 0x0016         
000016 c55c                          RJMP TIMER1_COMPA	// Vector de interrupción para TIMER1_COMPA 
                                 
                                 
                                 
                                 .org 0x0034
                                 
                                 SETUP:
                                     // Configuraci?n de la pila
000034 ef0f                          LDI     R16, LOW(RAMEND)
000035 bf0d                          OUT     SPL, R16
000036 e008                          LDI     R16, HIGH(RAMEND)
000037 bf0e                          OUT     SPH, R16
                                 		
                                 // ------------------------------------
                                 	
                                 //input botones (pullup)
000038 9820                      	CBI DDRB, DDB0
000039 9a28                      	SBI PORTB, PORTB0
00003a 9821                      	CBI DDRB, DDB1
00003b 9a29                      	SBI PORTB, PORTB1
00003c 9822                      	CBI DDRB, DDB2
00003d 9a2a                      	SBI PORTB, PORTB2
00003e 9823                      	CBI DDRB, DDB3
00003f 9a2b                      	SBI PORTB, PORTB3
                                 // Salidas LEDs (PC0-PC5) y (PD3) (apagados) (7 segmentos)
000040 9a38                      	SBI DDRC, DDC0    // PC0 salida
000041 9840                          CBI PORTC, PORTC0
000042 9a39                      	SBI DDRC, DDC1    // PC1 salida
000043 9841                          CBI PORTC, PORTC1
000044 9a3a                      	SBI DDRC, DDC2    // PC2 salida
000045 9842                          CBI PORTC, PORTC2
000046 9a3b                      	SBI DDRC, DDC3    // PC3 salida
000047 9843                          CBI PORTC, PORTC3
000048 9a3c                      	SBI DDRC, DDC4    // PC4 salida
000049 9844                          CBI PORTC, PORTC4
00004a 9a3d                      	SBI DDRC, DDC5    // PC5 salida
00004b 9845                          CBI PORTC, PORTC5
00004c 9a52                      	SBI DDRD, DDD2    // PD2 Salida
00004d 985a                          CBI PORTD, PORTD2 
                                 	// Salidas para habilitar que display actualizar (PD3-PD6)
00004e 9a53                      	SBI DDRD, DDD3    // PD3 Salida
00004f 985b                          CBI PORTD, PORTD3 
000050 9a54                      	SBI DDRD, DDD4    // PD4 Salida
000051 985c                          CBI PORTD, PORTD4
000052 9a55                      	SBI DDRD, DDD5    // PD5 Salida
000053 985d                          CBI PORTD, PORTD5 
000054 9a56                      	SBI DDRD, DDD6    // PD6 Salida
000055 985e                          CBI PORTD, PORTD6  
                                 	//LEDS ":"
000056 9a25                      	SBI DDRB, DDB5    // PB5 salida
000057 982d                          CBI PORTB, PORTB5
                                 	//LED ALARMA
000058 9a24                      	SBI DDRB, DDB4    // PB4 salida
000059 982c                          CBI PORTB, PORTB4
                                 	// LED MODO
00005a 9a57                      	SBI DDRD, DDD7    // PD7 salida
00005b 985f                          CBI PORTD, PORTD7
                                 	// Configuración Timer1 para 1 minuto en modo CTC ----------------------------------------------------------------------------------
                                 
                                 
                                 	// Configurar modo CTC (WGM12=1) y prescaler 1024 (CS12=1, CS10=1) 
00005c e00d                      	LDI R16, (1 << WGM12) | (1 << CS12) | (0 << CS11) | (1 << CS10)
00005d 9300 0081                 	STS TCCR1B, R16
                                 
                                 	// Cargar OCR1A (para 16 MHz) 1E83 (medio sec)  (00FF) (pruebas)
                                 	
00005f e10e                      	LDI R16, 0x1E
000060 9300 0089                 	STS OCR1AH, R16
000062 e803                      	LDI R16, 0x83
000063 9300 0088                 	STS OCR1AL, R16
                                 
                                 
                                 	// Inicializar TCNT1 a 0
000065 2700                      	CLR R16
000066 9300 0085                 	STS TCNT1H, R16
000068 9300 0084                 	STS TCNT1L, R16
                                 
00006a e002                      	LDI R16, (1 << OCIE1A)
00006b 9300 006f                     STS TIMSK1, R16
                                 
                                 		
                                 	// Habilita interrupciones del puertoB --------------------------------
00006d e001                      	LDI r16, (1 << PCIE0)
00006e 9300 0068                 	STS PCICR, r16
                                 	// Botones PB0 -> PB3
000070 e00f                      	LDI r16, (1 << PCINT0) | (1 << PCINT1) | (1 << PCINT2) | (1 << PCINT3)
000071 9300 006b                 	STS PCMSK0, r16
                                 
                                 
                                 	// INICIALIZAR VARIABLES EN SRAM
000073 e000                          LDI R16, 0
                                 
000074 e001                          LDI R16, 1              // Día y mes empieza en 1
000075 9300 0104                     STS unidadesDIA, R16
000077 9300 0106                     STS unidadesMES, R16
000079 e000                          LDI R16, 0
00007a 9300 0108                     STS Botonespressint, R16
00007c 9300 0109                     STS Botonespresspasado, R16
00007e 9300 0100                 	STS unidadesMIN, R16
000080 9300 0101                     STS decenasMIN, R16
000082 9300 0102                     STS unidadesHOR, R16
000084 9300 0103                     STS decenasHOR, R16
000086 9300 0107                 	STS decenasMES, R16
000088 9300 0105                 	STS decenasDIA, R16
00008a 9300 0116                 	STS alarmaUM, R16			
00008c 9300 0117                 	STS alarmaDM, R16		
00008e 9300 0118                 	STS alarmaUH, R16			
000090 9300 0119                 	STS alarmaDH, R16				
                                 
                                 
                                     // Inicializar registros
000092 2700                          CLR R16		// HORAMIN (0) / (MESDIA(1) 
000093 2711                          CLR R17		// Contador de segundos
000094 2722                          CLR R18		// Cuenta unidades Minutos	 // y de DIAS
000095 2733                      	CLR R19		// Estado real de los botones
000096 2744                      	CLR R20		// Modo
000097 2755                          CLR R21		// Seleciona Display
000098 2766                      	CLR R22		// Cuenta Decenas Minutos	 // y de DIAS
000099 2777                      	CLR R23		// Valor a buscar en el .db
00009a 2788                      	CLR R24		// Cuenta HORAS			     // y MES
00009b 2799                      	CLR R25		// Agarra los valores de R23 Para Actualizar el display
00009c 27aa                      	CLR R26		// Decenas de HORAS		     // y MES
00009d 27bb                      	CLR R27		// Carry
00009e 27cc                      	CLR R28		// VARX (solo la llamo para comparaciones no guarda nada)
00009f 27dd                      	CLR R29		// VARX 2
0000a0 27ee                      	CLR R30		// Para Z low
0000a1 27ff                      	CLR R31		// Para Z high
                                 
0000a2 9478                          SEI        // Habilitar interrupciones globales
                                 
                                 //------------------------------------------------------------------------------------- ACABA CONFIG----------------------------------------------------------------------------------------
                                 
                                 MAIN_LOOP:
0000a3 940e 00a8                 	CALL MODO 
0000a5 940e 043f                 	CALL DISPF
0000a7 cffb                      	RJMP MAIN_LOOP
                                 
                                 MODO:   //-------------------------------------------------------------------------------------------MODO SEL
0000a8 3040                          CPI R20, 0  // horas y minutos
0000a9 f059                          BREQ MODO0
                                     
0000aa 3041                          CPI R20, 1 // dias y meses
0000ab f079                          BREQ MODO1
                                     
0000ac 3042                          CPI R20, 2  // config de HM
0000ad f091                          BREQ MODO2
                                     
0000ae 3043                          CPI R20, 3 // config de DM
0000af f0b1                          BREQ MODO3
                                     
0000b0 3044                          CPI R20, 4 // config alarma
0000b1 f0d1                          BREQ MODO4
                                     
0000b2 3045                          CPI R20, 5 // set/reset alarma
0000b3 f0f1                          BREQ MODO5
                                 
0000b4 2744                      	CLR R20  //(reinicia la cuenta de modos) y sigue al modo0
                                 
                                 
                                 // PORTD7 Apagado  = Hora Min / Encendido = Mes / Dia
                                 // PORTB5 (puntos) = Parpadeando = tiempo corre / encendido = config
                                 
                                 // --------------------------------------------------------------------------------------------MODOS 
                                 MODO0: //HORAS / MINUTOS
                                 // llama la funcion que cuenta el tiempo
                                 // y asigna r16 para que se muestre HH : MM
                                 // des activa el led naranja para indicar HH:MM
0000b5 2700                      	CLR R16
0000b6 985f                      	CBI PORTD, PORTD7
0000b7 982c                      	CBI PORTB, PORTB4 //TEMPORAL................................
0000b8 940e 048f                     CALL TIEMPO
0000ba c01d                          RJMP FIN_COMPARAR
                                 
                                 MODO1: //DIA / MES
                                 // asigna r16 para que se muestre DD : MES
                                 // activa el led naranja para indicar DD:MES
0000bb e001                      	LDI R16, 1
0000bc 9a5f                      	SBI PORTD, PORTD7
0000bd 940e 048f                     CALL TIEMPO
0000bf c018                          RJMP FIN_COMPARAR
                                 
                                 MODO2: // CONFIG HM
                                 //	asigna r16 para que se muestre HH : MM
                                 // des activa el led naranja para indicar HH:MM
                                 // Enciende los : para indicar modo config
0000c0 2700                      	CLR R16
0000c1 985f                      	CBI PORTD, PORTD7
0000c2 9a2d                      	SBI PORTB, PORTB5
0000c3 940e 0118                 	CALL CONFIGRELOJ
0000c5 c012                          RJMP FIN_COMPARAR
                                 
                                 
                                 MODO3: // CONGIG MD
                                 // asigna r16 para que se muestre DD : MES
                                 // activa el led naranja para indicar DD:MES
                                 // Enciende los : para indicar modo config
0000c6 e001                      	LDI R16, 1
0000c7 9a2d                      	SBI PORTB, PORTB5
0000c8 9a5f                      	SBI PORTD, PORTD7
0000c9 940e 0118                 	CALL CONFIGRELOJ
0000cb c00c                          RJMP FIN_COMPARAR
                                 
                                 MODO4: // CONFIG ALARMA
                                 //	asigna r16 para que se muestre Alarma
0000cc e002                      	LDI R16, 2
0000cd 982d                      	CBI PORTB, PORTB5	// los : no se encienden (modo alarma)
0000ce 9a5f                      	SBI PORTD, PORTD7	// no se puede activar alarma
0000cf 940e 053c                 	CALL ALARMACONFIG
0000d1 c006                          RJMP FIN_COMPARAR
                                 
                                 MODO5: // APAGAR ALARMA
                                  //	asigna r16 para que se muestre Alarma
0000d2 e002                      	LDI R16, 2
0000d3 982d                      	CBI PORTB, PORTB5	// los : no se encienden (modo alarma)
0000d4 9a5f                      	SBI PORTD, PORTD7	//	indica que se puede activar alarma
0000d5 940e 0572                 	CALL ALARMACONFIGON
0000d7 c000                          RJMP FIN_COMPARAR
                                 
                                 FIN_COMPARAR:
0000d8 9508                          RET
                                 
                                 //--------------------------------------------------------------------------LOAD y SAVE 
                                 // para reducir espacio en el codigo
                                 LOADHM:
0000d9 9120 0100                 	LDS R18, unidadesMIN    // Cargar Unidades de Minuto
0000db 9160 0101                     LDS R22, decenasMIN     // Cargar Decenas de Minuto
0000dd 9180 0102                     LDS R24, unidadesHOR    // Cargar Unidades de Hora
0000df 91a0 0103                     LDS R26, decenasHOR     // Cargar Decenas de Hora
0000e1 9508                      	RET
                                 LOADDM:
0000e2 9120 0104                 	LDS R18, unidadesDIA    // Cargar Unidades de DIA
0000e4 9160 0105                     LDS R22, decenasDIA     // Cargar Decenas de DIA
0000e6 9180 0106                     LDS R24, unidadesMES    // Cargar Unidades de MES
0000e8 91a0 0107                     LDS R26, decenasMES     // Cargar Decenas de MES
0000ea 9508                      	RET
                                 //invertido para el display	
                                 LOADDMINV:
0000eb 9180 0104                 	LDS R24, unidadesDIA    // Cargar Unidades de DIA
0000ed 91a0 0105                     LDS R26, decenasDIA     // Cargar Decenas de DIA
0000ef 9120 0106                     LDS R18, unidadesMES    // Cargar Unidades de MES
0000f1 9160 0107                     LDS R22, decenasMES     // Cargar Decenas de MES
0000f3 9508                      	RET
                                 SAVEHM:
0000f4 9320 0100                 	STS unidadesMIN, R18    // Guardar Unidades de Minuto
0000f6 9360 0101                     STS decenasMIN, R22     // Guardar Decenas de Minuto
0000f8 9380 0102                     STS unidadesHOR, R24    // Guardar Unidades de Hora
0000fa 93a0 0103                     STS decenasHOR, R26     // Guardar Decenas de Hora
0000fc 9508                      	RET
                                 SAVEDM:
0000fd 9320 0104                 	STS unidadesDIA, R18    // Guardar Unidades de DIA
0000ff 9360 0105                     STS decenasDIA, R22     // Guardar Decenas de DIA
000101 9380 0106                     STS unidadesMES, R24    // Guardar Unidades de MES
000103 93a0 0107                     STS decenasMES, R26     // Guardar Decenas de MES
000105 9508                      	RET
                                 LOADAL:
000106 9120 0116                 	LDS R18, alarmaUM	
000108 9160 0117                 	LDS R22, alarmaDM
00010a 9180 0118                 	LDS R24, alarmaUH	
00010c 91a0 0119                 	LDS R26, alarmaDH
00010e 9508                      	RET
                                 SAVEAL:
00010f 9320 0116                 	STS alarmaUM, R18	
000111 9360 0117                 	STS alarmaDM, R22	
000113 9380 0118                 	STS alarmaUH, R24		
000115 93a0 0119                 	STS alarmaDH, R26
000117 9508                      	RET
                                 
                                 
                                 //--------------------------------------------------------------------------------------CONFIGRELOJ
                                 //Toda la logia para la suma y resta manual del reloj
                                 
                                 CONFIGRELOJ:
                                 //R16 (0) MM:HH (1) DD:MM 
                                 
000118 3001                      	CPI R16, 1
000119 f029                          BREQ MESESyDIA
                                     // si e 0 es horaymin
00011a 940e 00d9                 	CALL LOADHM	
00011c 940e 0236                 	CALL CONFIGHORAMIN
00011e 9508                      	RET
                                 MESESyDIA:
00011f 940e 00e2                 	CALL LOADDM	
000121 940e 0124                 	CALL CONFIGMESDIA
000123 9508                      	RET
                                 	
                                 //------------------------------------------------------------------------------------MESESyDIS config
                                 //Configmen (0) nada (1) restar 
                                 //Configmas (0) nada (1) sumar
                                 CONFIGMESDIA:
                                 	//mira si hay que sumar
000124 91c0 010c                 	LDS R28, Configmas  
000126 30c1                      	CPI R28, 1
000127 f029                      	BREQ SUMARDM1
                                 	//mira si hay que restar
000128 91c0 010d                 	LDS R28, Configmen
00012a 30c1                      	CPI R28, 1
00012b f059                      	BREQ RESTADM1
                                 	//si no pasa nada regresa
00012c 9508                      	RET
                                 
                                 
                                 SUMARDM1:
00012d 940e 00e2                 	CALL LOADDM
00012f 940e 0141                 	CALL SUMARDM
000131 93cf                      		PUSH R28
000132 27cc                      		CLR R28
000133 93c0 010c                 		STS Configmas, R28
000135 91cf                      		POP R28
000136 9508                      	RET
                                 RESTADM1:
000137 940e 00e2                 	CALL LOADDM
000139 940e 0228                 	CALL RESTADM
00013b 93cf                      		PUSH R28
00013c 27cc                      		CLR R28
00013d 93c0 010c                 		STS Configmas, R28
00013f 91cf                      		POP R28
000140 9508                      	RET
                                 //--------------------------------SUMA DIAMES
                                 SUMARDM:
000141 91c0 010b                 	LDS R28, Selectordisp
                                 
000143 30c0                      	CPI R28, 0 // Compara con 0
000144 f031                          BREQ SuniDmes0
000145 30c1                          CPI R28, 1 // Compara con 1
000146 f039                          BREQ SdecDmes0
000147 30c2                          CPI R28, 2 // Compara con 2
000148 f041                          BREQ SuniDdia0 
000149 30c3                          CPI R28, 3 // Compara con 3
00014a f049                          BREQ SdecDdia0
                                 
                                 SuniDmes0:
00014b 940e 0157                 	CALL SuniDmes
00014d 9508                      	RET
                                 SdecDmes0:
00014e 940e 0172                 	CALL SdecDmes
000150 9508                      	RET
                                 SuniDdia0:
000151 940e 0187                 	CALL SuniDdia
000153 9508                      	RET
                                 SdecDdia0:
000154 940e 01e2                 	CALL SdecDdia
000156 9508                      	RET
                                 
                                 // Mess (0) 0-9 (1) 10-12
                                 // Mes-->  (0) 31 dias (1) 30 dias (2) 28 dias
                                 SuniDmes:
000157 940e 04f8                 		CALL MESLOG
000159 9583                      		INC R24
                                 	   
00015a 91c0 0111                 		LDS R28, Mess
00015c 30c0                      		CPI R28, 0  
00015d f011                      		BREQ MESNORMAL9
                                     
00015e 30c1                      		CPI R28, 1
00015f f039                      		BREQ MES109
                                 		
                                 		MESNORMAL9:
000160 308a                      		CPI R24, 10          // si alcanzan las decenas suma 1
000161 f058                      		BRLO TIMER_RET29      
000162 2788                      		CLR R24            
000163 95a3                      		INC R26              // Incrementar decenas de mes      
000164 2766                      		CLR R22
000165 e021                      		LDI R18, 1 
000166 c006                      		RJMP TIMER_RET29
                                 
                                 		MES109:
000167 3083                      		CPI R24, 3          // si alcanza 3 reinicia
000168 f020                      		BRLO TIMER_RET29      
000169 e081                      		LDI R24, 1            
00016a 27aa                      		CLR R26   
00016b 2766                      		CLR R22
00016c e021                      		LDI R18, 1    	 
                                 	TIMER_RET29:
00016d 940e 0536                 		CALL cerocero      // arreglotemp
00016f 940e 00fd                 		CALL SAVEDM
000171 9508                      		RET
                                 SdecDmes:
000172 95a3                      		INC R26
000173 30a1                      		CPI R26, 1
000174 f021                      		BREQ TIMER_RET210
000175 27aa                      		CLR R26
000176 940e 00fd                 		CALL SAVEDM
000178 9508                      		RET
                                 		TIMER_RET210:
000179 3080                      		CPI R24, 0
00017a f031                      		BREQ TTIMER_RET21
00017b 3081                      		CPI R24, 1
00017c f021                      		BREQ TTIMER_RET21
00017d 3082                      		CPI R24, 2
