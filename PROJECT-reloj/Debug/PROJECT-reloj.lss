                                 //----------------------------------------------------------------------------------------------DISPF
                                 // toda la logica para el funcionamiento de los displays
                                 DISPF:
                                 
000421 3001                      	CPI R16, 1
000422 f011                          BREQ MESDIA
                                     
000423 3000                          CPI R16, 0
000424 f019                          BREQ HORAMIN
                                 
                                 MESDIA:
000425 940e 00df                 	CALL LOADDMINV
000427 c002                      	RJMP DISPSELCALC
                                 HORAMIN:
000428 940e 00cd                 	CALL LOADHM
                                 
                                 DISPSELCALC:
                                 
00042a 3054                          CPI R21, 4
00042b f010                      	BRLO DISPSEL     // Si R21 < 4, está bien
00042c 2755                          CLR R21          // Si R21 >= 4, resetea a 0    
00042d 9508                      	RET
                                 
                                 DISPSEL:
00042e 940e 0432                 	CALL DISPLAYSEL
000430 9553                      	INC R21 //Va haciendo la cuenta para actulizar los contadores individualmente
000431 9508                          RET
                                 
                                 DISPLAYSEL:
                                 
000432 3050                          CPI R21, 0 // Compara con 0
000433 f031                          BREQ DISP0 // Salta a DISP0 si R21 = 0
000434 3051                          CPI R21, 1 // Compara con 1
000435 f051                          BREQ DISP1 // Salta a DISP1 si R21 = 1
000436 3052                          CPI R21, 2 // Compara con 2
000437 f071                          BREQ DISP2 // Salta a DISP2 si R21 = 2
000438 3053                          CPI R21, 3 // Compara con 3
000439 f091                          BREQ DISP3 // Salta a DISP3 si R21 = 3
                                 	//nunca deberia pasar sin saltar
                                 
                                 DISP0:
00043a 985c                          CBI PORTD, 4    // Apaga PD4
00043b 985d                          CBI PORTD, 5    // Apaga PD5
00043c 985e                          CBI PORTD, 6    // Apaga PD6
00043d 9a5b                          SBI PORTD, 3    // Enciende PD3 (DISP0)
00043e 2f72                      	MOV R23, R18	// Cuenta de Unidades S a R23
00043f c012                      	RJMP DISPLAY
                                 
                                 DISP1:
000440 985b                          CBI PORTD, 3    // Apaga PD3
000441 985d                          CBI PORTD, 5    // Apaga PD5
000442 985e                          CBI PORTD, 6    // Apaga PD6
000443 9a5c                          SBI PORTD, 4    // Enciende PD4 (DISP1)
000444 2f76                      	MOV R23, R22	// Cuenta de Decenas S a R23
000445 c00c                          RJMP DISPLAY
                                 
                                 DISP2:
000446 985b                          CBI PORTD, 3    // Apaga PD3
000447 985c                          CBI PORTD, 4    // Apaga PD4
000448 985e                          CBI PORTD, 6    // Apaga PD6
000449 9a5d                          SBI PORTD, 5    // Enciende PD5 (DISP2)
00044a 2f78                      	MOV R23, R24	// Cuenta de Unidades S a R23
00044b c006                          RJMP DISPLAY
                                 
                                 DISP3:
00044c 985b                          CBI PORTD, 3    // Apaga PD3
00044d 985c                          CBI PORTD, 4    // Apaga PD4
00044e 985d                          CBI PORTD, 5    // Apaga PD5
00044f 9a5e                          SBI PORTD, 6    // Enciende PD6 (DISP3)
000450 2f7a                      	MOV R23, R26	// Cuenta de Decenas S a R23
000451 c000                          RJMP DISPLAY
                                 
                                 DISPLAY:
000452 934f                      	PUSH R20
000453 93ff                      	PUSH ZH
000454 93ef                          PUSH ZL
                                 
000455 e0fb                          LDI ZH, HIGH(disp7seg << 1)
000456 e1ea                          LDI ZL, LOW(disp7seg << 1)
                                 
                                 	// busca los valores para el 7 segmentos
000457 0f77                      	LSL R23		//mueve los bits a la iz (multiplica por 2)
000458 0fe7                      	ADD ZL, R23
000459 e040                      	LDI R20, 0
00045a 1ff4                      	ADC ZH, R20
00045b 9174                      	LPM R23, Z
                                 
00045c 91ef                      	POP ZL
00045d 91ff                          POP ZH
00045e 914f                      	POP R20
                                 
                                 	//Actualiza todo el portC (6 segmentos)
00045f 2f97                      	MOV R25, R23
000460 b998                      	OUT PORTC, R25  
                                 	//Actualiza el ultimo segmento
000461 fd96                      	SBRC R25, 6
000462 9a5a                          SBI PORTD, PORTD2
000463 ff96                          SBRS R25, 6
000464 985a                          CBI PORTD, PORTD2
                                 
                                 	//Limpia para que no afecte los otros diplays
000465 2799                      	CLR R25
000466 b998                      	OUT PORTC, R25  
                                 	//Actualiza el ultimo segmento
000467 fd96                      	SBRC R25, 6
000468 9a5a                          SBI PORTD, PORTD2
000469 ff96                          SBRS R25, 6
00046a 985a                          CBI PORTD, PORTD2 
00046b 9508                      RET
                                 
                                 
