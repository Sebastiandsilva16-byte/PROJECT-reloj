000487 ef1f                          LDI R17, 255     // Loop interno
                                 DELAY_10MS_LOOP2:
000488 951a                          DEC R17
000489 f7f1                          BRNE DELAY_10MS_LOOP2
00048a 950a                          DEC R16
00048b f7d9                          BRNE DELAY_10MS_LOOP1
                                 	
00048c b113                      	IN	R17, PINB			 // Leer estado de los botones
00048d 9310 0108                 	STS	Botonespressint, R17 // Guardar en variable de interrupción
00048f 9100 0108                 	LDS R16, Botonespressint
000491 9300 010a                     STS Botonespresspasado2, R16
                                 
                                 	// Comparar con el valor pasado	
000493 9100 0109                 	LDS R16, Botonespresspasado
000495 9110 010a                 	LDS R17, Botonespresspasado2
                                 
000497 1701                          CP R16, R17            // Comparara el estado pasado con el presente
000498 f529                          BRNE FINBOTONES            // Si son diferentes, salir
                                 	
000499 2f30                      	MOV R19, R16   // se guardan los verdaderos valores del boton
                                 	
                                 // Guardar bit PB0
00049a fb30                      BST R19, 0          // Store bit from register T flag (PB0)
00049b f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
00049c 93c0 0112                 STS PBceroB, R28    // Store R28 en variable PBceroB
                                 
                                 // Guardar bit PB1
00049e fb31                      BST R19, 1          // Store bit from register T flag (PB1)
00049f f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
0004a0 93c0 0113                 STS PBunoB, R28     // Store R28 en variable PBunoB
                                 
                                 // Guardar bit PB2
0004a2 fb32                      BST R19, 2          // Store bit from register T flag (PB2)
0004a3 f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
0004a4 93c0 0114                 STS PBdosB, R28     // Store R28 en variable PBdosB
                                 
                                 // Guardar bit PB3
0004a6 fb33                      BST R19, 3          // Store bit from register T flag (PB3)
0004a7 f9c0                      BLD R28, 0          // Load bit from T flag to R28 bit 0
0004a8 93c0 0115                 STS PBtresB, R28    // Store R28 en variable PBtresB
                                 
                                 // Cargar las variables en R28 y evaluar con SBRC
0004aa 91c0 0112                 LDS R28, PBceroB    // Cargar PBceroB en R28
0004ac ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
0004ad 940e 04c3                 CALL boton_PB0
                                 
0004af 91c0 0113                 LDS R28, PBunoB     // Cargar PBunoB en R28
0004b1 ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
0004b2 940e 04c5                 CALL boton_PB1
                                 
0004b4 91c0 0114                 LDS R28, PBdosB     // Cargar PBdosB en R28
0004b6 ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
0004b7 940e 04ce                 CALL boton_PB2
                                 
0004b9 91c0 0115                 LDS R28, PBtresB    // Cargar PBtresB en R28
0004bb ffc0                      SBRS R28, 0         // Skip if bit 0 of R28 is clear (si es 0 salta, si es 1 ejecuta)
0004bc 940e 04d9                 CALL boton_PB3
                                 
                                 	FINBOTONES:
                                 
0004be 911f                      	POP R17
0004bf 910f                      	POP R16
0004c0 bf0f                      	OUT SREG, R16
0004c1 910f                      	POP R16
0004c2 9518                      	RETI
                                 
