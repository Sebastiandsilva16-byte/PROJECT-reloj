000570 9503                      	INC R16
000571 3004                      	CPI R16, 4
000572 f008                      	BRLO SDOVER
000573 2700                      	CLR R16
                                 SDOVER:
000574 9300 010b                 	STS Selectordisp, R16
000576 9508                      	RET
                                 
