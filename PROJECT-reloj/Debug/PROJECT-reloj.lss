                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 // Creado: 16/02/2026
                                 // Autor : Sebastian Da Silva
                                 // Descripcion:Reloj proyecto
                                 
                                 .include "M328PDEF.inc"
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 .dseg
                                 .org  SRAM_START
                                 .dseg
                                 	.org 0x0100           
000100                           	unidadesMIN:			.byte 1
000101                           	decenasMIN:				.byte 1
000102                           	unidadesHOR:			.byte 1
000103                           	decenasHOR:				.byte 1
000104                           	unidadesDIA:			.byte 1
000105                           	decenasDIA:				.byte 1
000106                           	unidadesMES:			.byte 1
000107                           	decenasMES:				.byte 1
000108                           	Botonespressint:		.byte 1
000109                           	Botonespresspasado:     .byte 1
00010a                           	Botonespresspasado2:    .byte 1
00010b                           	TMPactual:				.byte 1
00010c                           	TMPalarma:				.byte 1
                                 
                                 	
                                 .cseg
                                 .org 0x0000
000000 c033                          RJMP SETUP
                                 .org 0x0008
000008 c1a8                      	RJMP INTBOTONES //interrpciones de botones portB
                                 .org 0x0016         
000016 c191                          RJMP TIMER1_COMPA	// Vector de interrupción para TIMER1_COMPA 
                                 
                                 
                                 
                                 .org 0x0034
                                 
                                 SETUP:
                                     // Configuraci?n de la pila
000034 ef0f                          LDI     R16, LOW(RAMEND)
000035 bf0d                          OUT     SPL, R16
000036 e008                          LDI     R16, HIGH(RAMEND)
000037 bf0e                          OUT     SPH, R16
                                 		
                                 // ------------------------------------
                                 	
                                 //input botones (pullup)
000038 9820                      	CBI DDRB, DDB0
000039 9a28                      	SBI PORTB, PORTB0
00003a 9821                      	CBI DDRB, DDB1
00003b 9a29                      	SBI PORTB, PORTB1
00003c 9822                      	CBI DDRB, DDB2
00003d 9a2a                      	SBI PORTB, PORTB2
00003e 9823                      	CBI DDRB, DDB3
00003f 9a2b                      	SBI PORTB, PORTB3
                                 // Salidas LEDs (PC0-PC5) y (PD3) (apagados) (7 segmentos)
000040 9a38                      	SBI DDRC, DDC0    // PC0 salida
000041 9840                          CBI PORTC, PORTC0
000042 9a39                      	SBI DDRC, DDC1    // PC1 salida
000043 9841                          CBI PORTC, PORTC1
000044 9a3a                      	SBI DDRC, DDC2    // PC2 salida
000045 9842                          CBI PORTC, PORTC2
000046 9a3b                      	SBI DDRC, DDC3    // PC3 salida
000047 9843                          CBI PORTC, PORTC3
000048 9a3c                      	SBI DDRC, DDC4    // PC4 salida
000049 9844                          CBI PORTC, PORTC4
00004a 9a3d                      	SBI DDRC, DDC5    // PC5 salida
00004b 9845                          CBI PORTC, PORTC5
00004c 9a52                      	SBI DDRD, DDD2    // PD2 Salida
00004d 985a                          CBI PORTD, PORTD2 
                                 	// Salidas para habilitar que display actualizar (PD3-PD6)
00004e 9a53                      	SBI DDRD, DDD3    // PD3 Salida
00004f 985b                          CBI PORTD, PORTD3 
000050 9a54                      	SBI DDRD, DDD4    // PD4 Salida
000051 985c                          CBI PORTD, PORTD4
000052 9a55                      	SBI DDRD, DDD5    // PD5 Salida
000053 985d                          CBI PORTD, PORTD5 
000054 9a56                      	SBI DDRD, DDD6    // PD6 Salida
000055 985e                          CBI PORTD, PORTD6  
                                 	//LEDS ":"
000056 9a25                      	SBI DDRB, DDB5    // PB5 salida
000057 982d                          CBI PORTB, PORTB5
                                 	// LED MODO
000058 9a57                      	SBI DDRD, DDD7    // PD7 salida
000059 985f                          CBI PORTD, PORTD7
                                 	// Configuración Timer1 para 1 minuto en modo CTC ----------------------------------------------------------------------------------
                                 
                                 
                                 	// Configurar modo CTC (WGM12=1) y prescaler 1024 (CS12=1, CS10=1) 
00005a e00d                      	LDI R16, (1 << WGM12) | (1 << CS12) | (0 << CS11) | (1 << CS10)
00005b 9300 0081                 	STS TCCR1B, R16
                                 
                                 	// Cargar OCR1A (para 16 MHz) 1E83 (medio sec)  (00FF) (pruebas)
                                 	
00005d e000                      	LDI R16, 0x00
00005e 9300 0089                 	STS OCR1AH, R16
000060 e00f                      	LDI R16, 0x0F
000061 9300 0088                 	STS OCR1AL, R16
                                 
                                 
                                 	// Inicializar TCNT1 a 0
000063 2700                      	CLR R16
000064 9300 0085                 	STS TCNT1H, R16
000066 9300 0084                 	STS TCNT1L, R16
                                 
000068 e002                      	LDI R16, (1 << OCIE1A)
000069 9300 006f                     STS TIMSK1, R16
                                 
                                 		
                                 	// Habilita interrupciones del puertoB --------------------------------
00006b e001                      	LDI r16, (1 << PCIE0)
00006c 9300 0068                 	STS PCICR, r16
                                 	// Botones PB0 -> PB3
00006e e00f                      	LDI r16, (1 << PCINT0) | (1 << PCINT1) | (1 << PCINT2) | (1 << PCINT3)
00006f 9300 006b                 	STS PCMSK0, r16
                                 
                                 
                                 	// INICIALIZAR VARIABLES EN SRAM
000071 e000                          LDI R16, 0
                                 
000072 e001                          LDI R16, 1              // Día y mes empieza en 1
000073 9300 0105                     STS decenasDIA, R16
000075 9300 0106                     STS unidadesMES, R16
000077 e000                          LDI R16, 0
000078 9300 0108                     STS Botonespressint, R16
00007a 9300 0109                     STS Botonespresspasado, R16
00007c 9300 0100                 	STS unidadesMIN, R16
00007e 9300 0101                     STS decenasMIN, R16
000080 9300 0102                     STS unidadesHOR, R16
000082 9300 0103                     STS decenasHOR, R16
000084 9300 0107                 	STS decenasMES, R16
000086 9300 0104                 	STS unidadesDIA, R16
                                 
                                 
                                     // Inicializar registros
000088 2700                          CLR R16		// HORAMIN (0) / (MESDIA(1) 
000089 2711                          CLR R17		// Contador de segundos
00008a 2722                          CLR R18		// Cuenta unidades Minutos	 // y de DIAS
00008b 2733                      	CLR R19		// Estado real de los botones
00008c 2744                      	CLR R20		// Modo
00008d 2755                          CLR R21		// Seleciona Display
00008e 2766                      	CLR R22		// Cuenta Decenas Minutos	 // y de DIAS
00008f 2777                      	CLR R23		// Valor a buscar en el .db
000090 2788                      	CLR R24		// Cuenta HORAS			     // y MES
000091 2799                      	CLR R25		// Agarra los valores de R23 Para Actualizar el display
000092 27aa                      	CLR R26		// Decenas de HORAS		     // y MES
000093 27bb                      	CLR R27		// Carry
000094 27cc                      	CLR R28		//
000095 27dd                      	CLR R29
000096 27ee                      	CLR R30		// Para Z low
000097 27ff                      	CLR R31		// Para Z high
                                 
000098 9478                          SEI        // Habilitar interrupciones globales
                                 
                                 //------------------------------------------------------------------------------------- ACABA CONFIG----------------------------------------------------------------------------------------
                                 
                                 MAIN_LOOP:
000099 940e 009e                 	CALL MODO 
00009b 940e 00c0                 	CALL DISPF
00009d cffb                      	RJMP MAIN_LOOP
                                 
                                 MODO:
00009e 3040                          CPI R20, 0
00009f f059                          BREQ MODO0
                                     
0000a0 3041                          CPI R20, 1
0000a1 f071                          BREQ MODO1
                                     
0000a2 3042                          CPI R20, 2
0000a3 f089                          BREQ MODO2
                                     
0000a4 3043                          CPI R20, 3
0000a5 f099                          BREQ MODO3
                                     
0000a6 3044                          CPI R20, 4
0000a7 f0a9                          BREQ MODO4
                                     
0000a8 3045                          CPI R20, 5
0000a9 f0a1                          BREQ MODO5
                                 
0000aa 2744                      	CLR R20  //(reinicia lacuenat de modos) y sigue al modo0
                                 
                                 
                                 // PORTD7 Apagado  = Hora Min / Encendido = Mes / Dia
                                 // PORTB5 (puntos) = Parpadeando = tiempo corre / encendido = config
                                  
                                 MODO0: //HORAS / MINUTOS
0000ab 2700                      	CLR R16
0000ac 985f                      	CBI PORTD, PORTD7
0000ad 940e 0117                     CALL TIEMPO
0000af c00f                          RJMP FIN_COMPARAR
                                 
                                 MODO1: //DIA / MES
0000b0 e001                      	LDI R16, 1
0000b1 9a5f                      	SBI PORTD, PORTD7
0000b2 940e 0117                     CALL TIEMPO
0000b4 c00a                          RJMP FIN_COMPARAR
                                 
                                 MODO2: // CONFIG HM
0000b5 2700                      	CLR R16
0000b6 985f                      	CBI PORTD, PORTD7
0000b7 9a2d                      	SBI PORTB, PORTB5
0000b8 c006                          RJMP FIN_COMPARAR
                                 
                                 MODO3: // CONGIG MD
0000b9 e001                      	LDI R16, 1
0000ba 9a2d                      	SBI PORTB, PORTB5
0000bb 9a5f                      	SBI PORTD, PORTD7
0000bc c002                          RJMP FIN_COMPARAR
                                 
                                 MODO4: // CONFIG ALARMA
                                     // Código para modo 4
0000bd c001                          RJMP FIN_COMPARAR
                                 
                                 MODO5: // APAGAR ALARMA
                                     // Código para modo 5
0000be c000                          RJMP FIN_COMPARAR
                                 
                                 FIN_COMPARAR:
0000bf 9508                          RET
                                 
                                 DISPF:
                                 
0000c0 3001                      	CPI R16, 1
0000c1 f011                          BREQ MESDIA
                                     
0000c2 3000                          CPI R16, 0
0000c3 f049                          BREQ HORAMIN
                                 
                                 MESDIA:
0000c4 9180 0104                 	LDS R24, unidadesDIA    // Cargar Unidades de DIA
0000c6 91a0 0105                     LDS R26, decenasDIA     // Cargar Decenas de DIA
0000c8 9120 0106                     LDS R18, unidadesMES    // Cargar Unidades de MES
0000ca 9160 0107                     LDS R22, decenasMES     // Cargar Decenas de MES
                                 
0000cc c008                      	RJMP DISPSELCALC
                                 HORAMIN:
0000cd 9120 0100                 	LDS R18, unidadesMIN    // Cargar Unidades de Minuto
0000cf 9160 0101                     LDS R22, decenasMIN     // Cargar Decenas de Minuto
0000d1 9180 0102                     LDS R24, unidadesHOR    // Cargar Unidades de Hora
0000d3 91a0 0103                     LDS R26, decenasHOR     // Cargar Decenas de Hora
                                 
                                 DISPSELCALC:
                                 
0000d5 3054                          CPI R21, 4
0000d6 f010                      	BRLO DISPSEL     // Si R21 < 4, está bien
0000d7 2755                          CLR R21          // Si R21 >= 4, resetea a 0    
0000d8 9508                      	RET
                                 
                                 DISPSEL:
0000d9 940e 00dd                 	CALL DISPLAYSEL
0000db 9553                      	INC R21 //Va haciendo la cuenta para actulizar los contadores individualmente
0000dc 9508                          RET
                                 
                                 DISPLAYSEL:
                                 
0000dd 3050                          CPI R21, 0 // Compara con 0
0000de f031                          BREQ DISP0 // Salta a DISP0 si R21 = 0
0000df 3051                          CPI R21, 1 // Compara con 1
0000e0 f051                          BREQ DISP1 // Salta a DISP1 si R21 = 1
0000e1 3052                          CPI R21, 2 // Compara con 2
0000e2 f071                          BREQ DISP2 // Salta a DISP2 si R21 = 2
0000e3 3053                          CPI R21, 3 // Compara con 3
0000e4 f091                          BREQ DISP3 // Salta a DISP3 si R21 = 3
                                 	//nunca deberia pasar sin saltar
                                 
                                 DISP0:
0000e5 985c                          CBI PORTD, 4    // Apaga PD4
0000e6 985d                          CBI PORTD, 5    // Apaga PD5
0000e7 985e                          CBI PORTD, 6    // Apaga PD6
0000e8 9a5b                          SBI PORTD, 3    // Enciende PD3 (DISP0)
0000e9 2f72                      	MOV R23, R18	// Cuenta de Unidades S a R23
0000ea c012                      	RJMP DISPLAY
                                 
                                 DISP1:
0000eb 985b                          CBI PORTD, 3    // Apaga PD3
0000ec 985d                          CBI PORTD, 5    // Apaga PD5
0000ed 985e                          CBI PORTD, 6    // Apaga PD6
0000ee 9a5c                          SBI PORTD, 4    // Enciende PD4 (DISP1)
0000ef 2f76                      	MOV R23, R22	// Cuenta de Decenas S a R23
0000f0 c00c                          RJMP DISPLAY
                                 
                                 DISP2:
0000f1 985b                          CBI PORTD, 3    // Apaga PD3
0000f2 985c                          CBI PORTD, 4    // Apaga PD4
0000f3 985e                          CBI PORTD, 6    // Apaga PD6
0000f4 9a5d                          SBI PORTD, 5    // Enciende PD5 (DISP2)
0000f5 2f78                      	MOV R23, R24	// Cuenta de Unidades S a R23
0000f6 c006                          RJMP DISPLAY
                                 
                                 DISP3:
0000f7 985b                          CBI PORTD, 3    // Apaga PD3
0000f8 985c                          CBI PORTD, 4    // Apaga PD4
0000f9 985d                          CBI PORTD, 5    // Apaga PD5
0000fa 9a5e                          SBI PORTD, 6    // Enciende PD6 (DISP3)
0000fb 2f7a                      	MOV R23, R26	// Cuenta de Decenas S a R23
0000fc c000                          RJMP DISPLAY
                                 
                                 DISPLAY:
0000fd 934f                      	PUSH R20
0000fe 93ff                      	PUSH ZH
0000ff 93ef                          PUSH ZL
                                 
000100 e0f3                          LDI ZH, HIGH(disp7seg << 1)
000101 ede2                          LDI ZL, LOW(disp7seg << 1)
                                 
                                 	// busca los valores para el 7 segmentos
000102 0f77                      	LSL R23		//mueve los bits a la iz (multiplica por 2)
000103 0fe7                      	ADD ZL, R23
000104 e040                      	LDI R20, 0
000105 1ff4                      	ADC ZH, R20
000106 9174                      	LPM R23, Z
                                 
000107 91ef                      	POP ZL
000108 91ff                          POP ZH
000109 914f                      	POP R20
                                 
                                 	//Actualiza todo el portC (6 segmentos)
00010a 2f97                      	MOV R25, R23
00010b b998                      	OUT PORTC, R25  
                                 	//Actualiza el ultimo segmento
00010c fd96                      	SBRC R25, 6
00010d 9a5a                          SBI PORTD, PORTD2
00010e ff96                          SBRS R25, 6
00010f 985a                          CBI PORTD, PORTD2
                                 
                                 	//Limpia para que no afecte los otros diplays
000110 2799                      	CLR R25
000111 b998                      	OUT PORTC, R25  
                                 	//Actualiza el ultimo segmento
000112 fd96                      	SBRC R25, 6
000113 9a5a                          SBI PORTD, PORTD2
000114 ff96                          SBRS R25, 6
000115 985a                          CBI PORTD, PORTD2 
000116 9508                      RET
                                 
                                 
                                 TIEMPO:
                                 	
000117 9120 0100                 	LDS R18, unidadesMIN    // Cargar Unidades de Minuto
000119 9160 0101                     LDS R22, decenasMIN     // Cargar Decenas de Minuto
00011b 9180 0102                     LDS R24, unidadesHOR    // Cargar Unidades de Hora
00011d 91a0 0103                     LDS R26, decenasHOR     // Cargar Decenas de Hora
                                 
00011f 3011                      	CPI R17, 1 //segundos (118) (1 para pruebas de dia y mes)
000120 f0c0                          BRLO TIMER_RET
000121 2711                      	CLR R17
                                 
                                 	//Unidades de Minutos
000122 9523                      	INC R18
000123 302a                          CPI R18, 10
000124 f0a0                          BRLO TIMER_RET
000125 2722                      	CLR R18
                                 
000126 9563                      	INC R22			//Decenas de Minutos
000127 3066                      	CPI R22, 6
000128 f080                      	BRLO TIMER_RET
000129 2766                      	CLR R22
                                 
00012a 9583                      	INC R24			//Unidades de Horas
00012b 30a2                      	CPI R26, 2	
00012c f421                      	BRNE ZEROoDIEZ // revisa que no ha llegado a 20
00012d 3084                      	CPI R24, 4
00012e f050                      	BRLO TIMER_RET
00012f 2788                      	CLR R24
000130 c003                      	RJMP DECENASdeHORAS
                                 ZEROoDIEZ:
000131 308a                      	CPI R24, 10
000132 f030                      	BRLO TIMER_RET
000133 2788                      	CLR R24
                                 
                                 DECENASdeHORAS:
000134 95a3                      	INC R26			//Decenas de Horas
000135 30a3                      	CPI R26, 3
000136 f010                      	BRLO TIMER_RET
000137 27aa                      	CLR R26
000138 95b3                      	INC R27
                                 
                                 TIMER_RET:
                                 	//Ahora cambio para hacer lo de las horas
000139 9320 0100                 	STS unidadesMIN, R18    // Guardar Unidades de Minuto
00013b 9360 0101                     STS decenasMIN, R22     // Guardar Decenas de Minuto
00013d 9380 0102                     STS unidadesHOR, R24    // Guardar Unidades de Hora
00013f 93a0 0103                     STS decenasHOR, R26     // Guardar Decenas de Hora
000141 9120 0104                 	LDS R18, unidadesDIA    // Cargar Unidades de DIA
000143 9160 0105                     LDS R22, decenasDIA     // Cargar Decenas de DIA
000145 9180 0106                     LDS R24, unidadesMES    // Cargar Unidades de MES
000147 91a0 0107                     LDS R26, decenasMES     // Cargar Decenas de MES
                                 
                                 	// Verificar carry (ya paso un dia?)
000149 30b0                      	CPI R27, 0
00014a f109                      	BREQ TEMPORAL	  // Si R27 es 0, (no cambio nada en MES/DIA asi que sale)
00014b 9523                      	INC R18           // Si R27 está activo, sumar 1 a R18
00014c 27bb                      	CLR R27
                                 
                                 	// Verificar condiciones para saltar a 30dias
00014d 3084                      	CPI R24, 4        // żR24 es 4 (abril)?
00014e f059                      	BREQ TREINTA_DIAS
00014f 3086                      	CPI R24, 6        // żR24 es 6 (junio)?
000150 f049                      	BREQ TREINTA_DIAS
000151 3089                      	CPI R24, 9        // żR24 es 9 (septiembre)?
000152 f039                      	BREQ TREINTA_DIAS
                                 
                                 	// Verificar si R26=1 y R24=1 (noviembre)
000153 30a1                      	CPI R26, 1        // żR26 es 1?
000154 f411                      	BRNE VERIFICAR_28 // Si R26 no es 1, seguir a la siguiente verificación
000155 3081                      	CPI R24, 1        // żR24 es 1?
000156 f019                      	BREQ TREINTA_DIAS // Si ambos son 1, saltar a 30dias
                                 
                                 	//Verificar condiciones para saltar a 28dias
                                 	// (Como el reloj no cuenta ańos no voy a tomaren cuenta los ańos con 29 dias)
                                 	VERIFICAR_28:
000157 3082                      	CPI R24, 2        // żR24 es 2 (febrero)?
000158 f0a1                      	BREQ VEINTIOCHO_DIAS
000159 c023                      	RJMP TREINTA_Y_UN_DIAS 	//Todos los otros meses tienen 31 dias
                                 
                                 TREINTA_DIAS: // Aquí va la lógica para meses de 30 días ----------------------------------------------
00015a 3063                      	CPI R22, 3
00015b f029                      	BREQ TREINTA
00015c 302a                      	CPI R18, 10          // Comparar R18 (unidades de día) con 10
00015d f070                      	BRLO TEMPORAL      
00015e 2722                      	CLR R18              
00015f 9563                      	INC R22
000160 c006                      	RJMP TREINTAFIN
                                 	TREINTA:
000161 3021                      	CPI R18, 1    
000162 f1e0                      	BRLO TIMER_RET2      
000163 2722                      	CLR R18                    
000164 2766                      	CLR R22              
