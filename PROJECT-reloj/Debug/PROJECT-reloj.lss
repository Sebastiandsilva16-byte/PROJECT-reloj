00044d 9508                          RET
                                 
                                 //--------------------------------------------------------------------------------------------------------LOGICA DE DIAS
                                 // Mes-->  (0) 31 dias (1) 30 dias (2) 28 dias
                                 LOGDIAS:
                                 	// Verificar condiciones para saltar a 30dias
00044e 3084                      	CPI R24, 4        // żR24 es 4 (abril)?
00044f f081                      	BREQ MESUNO
000450 3086                      	CPI R24, 6        // żR24 es 6 (junio)?
000451 f071                      	BREQ MESUNO
000452 3089                      	CPI R24, 9        // żR24 es 9 (septiembre)?
000453 f061                      	BREQ MESUNO
                                 
                                 	// Verificar si R26=1 y R24=1 (noviembre)
000454 30a1                      	CPI R26, 1        // żR26 es 1?
000455 f421                      	BRNE VERIFICAR_28 // Si R26 no es 1, seguir a la siguiente verificación
000456 3081                      	CPI R24, 1        // żR24 es 1?
000457 f041                      	BREQ MESUNO // Si ambos son 1, saltar a 30dias
000458 3082                      	CPI R24, 2       // żR24 es 1?
000459 f011                      	BREQ MESZERO
                                 
                                 	//Verificar condiciones para saltar a 28dias
                                 	// (Como el reloj no cuenta ańos no voy a tomaren cuenta los ańos con 29 dias)
                                 	VERIFICAR_28:
00045a 3082                      	CPI R24, 2        // żR24 es 2 (febrero)?
00045b f041                      	BREQ MESDOS
                                 
                                 
                                 	MESZERO:
00045c 27cc                      		CLR R28
00045d 93c0 0110                 		STS	Mes, R28
00045f c007                      		RJMP LOGMESFIN
                                 	MESUNO:
000460 e0c1                      		LDI R28, 1
000461 93c0 0110                 		STS	Mes, R28
000463 c003                      		RJMP LOGMESFIN
                                 	MESDOS:
000464 e0c2                      		LDI R28, 2
000465 93c0 0110                 		STS	Mes, R28
                                 	LOGMESFIN:
000467 9508                      		RET
                                 //---------------------------------------------------------------otra variable  para la logica de los meses
                                 // Mess (0) 0-9 (1) 10-12
                                 MESLOG2:
000468 30a1                      	CPI R26, 1
000469 f020                      	BRLO MESS0
                                 MESS1:
00046a e0c1                      	LDI R28, 1
00046b 93c0 0111                 	STS	Mess, R28
00046d c003                      	RJMP MESSLOG2FIN
                                 MESS0:
00046e 27cc                      	CLR R28
00046f 93c0 0111                 	STS	Mess, R28
                                 
                                 MESSLOG2FIN: 
000471 9508                      	RET
                                 //--------------------------------------------------------------------------------------------------------INTERRUPCIONES
                                 
                                 // Rutina de interrupci?n del Timer1 - Modo COMPARE MATCH
                                 // Se encarga de contar los segundos
                                 TIMER1_COMPA:      
000472 930f                          PUSH R16
000473 b70f                          IN R16, SREG
000474 930f                          PUSH R16
                                 
                                 
000475 9513                          INC R17                 // Incrementar contador de ciclos
