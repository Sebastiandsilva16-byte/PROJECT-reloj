00019a f020                      	BRLO TIMER_RET2      
00019b e081                      	LDI R24, 1            
00019c 27aa                      	CLR R26   
00019d 2766                      	CLR R22
00019e e021                      	LDI R18, 1          
                                 
                                 
                                 	TIMER_RET2:
