000494 c003                      	RJMP Nocontar
                                 	Sicontar:
                                 
000495 3716                      	CPI R17, 118 //segundos (118) (1 para pruebas de dia y mes)
000496 f0c0                          BRLO TIMER_RET
000497 2711                      	CLR R17
                                 
                                 	Nocontar:
                                 
                                 	//Unidades de Minutos
000498 9523                      	INC R18
000499 302a                          CPI R18, 10
00049a f0a0                          BRLO TIMER_RET
00049b 2722                      	CLR R18
                                 
