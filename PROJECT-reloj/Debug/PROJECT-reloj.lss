                                 //----------------------------------------------------------------------------------------------DISPF
                                 // toda la logica para el funcionamiento de los displays
                                 DISPF:
                                 
00043f 3002                      	CPI R16, 2
000440 f021                          BREQ ALARMA
                                 
000441 3001                      	CPI R16, 1
000442 f029                          BREQ MESDIA
                                     
000443 3000                          CPI R16, 0
000444 f031                          BREQ HORAMIN
                                 
                                 
                                 
                                 ALARMA:
000445 940e 0106                 	CALL LOADAL
000447 c005                      	RJMP DISPSELCALC
                                 MESDIA:
000448 940e 00eb                 	CALL LOADDMINV
00044a c002                      	RJMP DISPSELCALC
                                 HORAMIN:
00044b 940e 00d9                 	CALL LOADHM
                                 
                                 DISPSELCALC:
                                 
00044d 3054                          CPI R21, 4
00044e f010                      	BRLO DISPSEL     // Si R21 < 4, está bien
00044f 2755                          CLR R21          // Si R21 >= 4, resetea a 0    
000450 9508                      	RET
                                 
                                 DISPSEL:
000451 940e 0455                 	CALL DISPLAYSEL
000453 9553                      	INC R21 //Va haciendo la cuenta para actulizar los contadores individualmente
000454 9508                          RET
                                 
                                 DISPLAYSEL:
                                 
000455 3050                          CPI R21, 0 // Compara con 0
000456 f031                          BREQ DISP0 // Salta a DISP0 si R21 = 0
000457 3051                          CPI R21, 1 // Compara con 1
000458 f051                          BREQ DISP1 // Salta a DISP1 si R21 = 1
000459 3052                          CPI R21, 2 // Compara con 2
00045a f071                          BREQ DISP2 // Salta a DISP2 si R21 = 2
00045b 3053                          CPI R21, 3 // Compara con 3
00045c f091                          BREQ DISP3 // Salta a DISP3 si R21 = 3
                                 	//nunca deberia pasar sin saltar
                                 
                                 DISP0:
00045d 985c                          CBI PORTD, 4    // Apaga PD4
00045e 985d                          CBI PORTD, 5    // Apaga PD5
00045f 985e                          CBI PORTD, 6    // Apaga PD6
000460 9a5b                          SBI PORTD, 3    // Enciende PD3 (DISP0)
000461 2f72                      	MOV R23, R18	// Cuenta de Unidades S a R23
000462 c012                      	RJMP DISPLAY
                                 
                                 DISP1:
000463 985b                          CBI PORTD, 3    // Apaga PD3
000464 985d                          CBI PORTD, 5    // Apaga PD5
000465 985e                          CBI PORTD, 6    // Apaga PD6
000466 9a5c                          SBI PORTD, 4    // Enciende PD4 (DISP1)
000467 2f76                      	MOV R23, R22	// Cuenta de Decenas S a R23
000468 c00c                          RJMP DISPLAY
                                 
                                 DISP2:
000469 985b                          CBI PORTD, 3    // Apaga PD3
00046a 985c                          CBI PORTD, 4    // Apaga PD4
00046b 985e                          CBI PORTD, 6    // Apaga PD6
00046c 9a5d                          SBI PORTD, 5    // Enciende PD5 (DISP2)
00046d 2f78                      	MOV R23, R24	// Cuenta de Unidades S a R23
00046e c006                          RJMP DISPLAY
                                 
                                 DISP3:
00046f 985b                          CBI PORTD, 3    // Apaga PD3
000470 985c                          CBI PORTD, 4    // Apaga PD4
000471 985d                          CBI PORTD, 5    // Apaga PD5
000472 9a5e                          SBI PORTD, 6    // Enciende PD6 (DISP3)
000473 2f7a                      	MOV R23, R26	// Cuenta de Decenas S a R23
000474 c000                          RJMP DISPLAY
                                 
                                 DISPLAY:
000475 934f                      	PUSH R20
000476 93ff                      	PUSH ZH
000477 93ef                          PUSH ZL
                                 
000478 e0fb                          LDI ZH, HIGH(disp7seg << 1)
000479 ede2                          LDI ZL, LOW(disp7seg << 1)
                                 
                                 	// busca los valores para el 7 segmentos
00047a 0f77                      	LSL R23		//mueve los bits a la iz (multiplica por 2)
00047b 0fe7                      	ADD ZL, R23
00047c e040                      	LDI R20, 0
00047d 1ff4                      	ADC ZH, R20
00047e 9174                      	LPM R23, Z
                                 
00047f 91ef                      	POP ZL
000480 91ff                          POP ZH
000481 914f                      	POP R20
                                 
                                 	//Actualiza todo el portC (6 segmentos)
000482 2f97                      	MOV R25, R23
000483 b998                      	OUT PORTC, R25  
                                 	//Actualiza el ultimo segmento
000484 fd96                      	SBRC R25, 6
000485 9a5a                          SBI PORTD, PORTD2
000486 ff96                          SBRS R25, 6
000487 985a                          CBI PORTD, PORTD2
                                 
                                 	//Limpia para que no afecte los otros diplays
000488 2799                      	CLR R25
000489 b998                      	OUT PORTC, R25  
                                 	//Actualiza el ultimo segmento
00048a fd96                      	SBRC R25, 6
00048b 9a5a                          SBI PORTD, PORTD2
00048c ff96                          SBRS R25, 6
00048d 985a                          CBI PORTD, PORTD2 
00048e 9508                      RET
                                 
                                 
