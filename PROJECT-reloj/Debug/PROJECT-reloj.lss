000519 f421                      	BRNE VERIFICAR_28 // Si R26 no es 1, seguir a la siguiente verificación
00051a 3081                      	CPI R24, 1        // żR24 es 1?
00051b f041                      	BREQ MESUNO // Si ambos son 1, saltar a 30dias
00051c 3082                      	CPI R24, 2       // żR24 es 1?
00051d f011                      	BREQ MESZERO
                                 
