0001e3 9a1d                      	SBI PINB, PINB5 
0001e4 9508                      	RET
                                 boton_PB2:
0001e5 9a1d                      	SBI PINB, PINB5 
0001e6 9508                      	RET
                                 boton_PB3:
0001e7 9a1d                      	SBI PINB, PINB5 
0001e8 9508                      	RET
                                 
                                 
                                 
