                                 // Toda la logica de la cuenta del tiempo
                                 TIEMPO:
                                 	
00048f 940e 00d9                 	CALL LOADHM
                                 	
                                 	// modos con la cuenta interrumpida
000491 3042                      	CPI R20, 2
