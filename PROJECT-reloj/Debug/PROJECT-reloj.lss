0004ac f1e8                      	BRLO TIMER_RET2     
0004ad e021                      	LDI R18, 1  
0004ae 2766                      	CLR R22              
0004af 9583                      	INC R24              // Incrementar unidades de mes
0004b0 c024                      	RJMP MESLOG //ahora va a ver la logica de los meses
                                 TEMPORAL:
0004b1 c023                      	RJMP MESLOG
                                 VEINTIOCHO_DIAS:	// Aquí va la lógica para febrero (28 días)----------------------------------------------------
0004b2 3062                      	CPI R22, 2
