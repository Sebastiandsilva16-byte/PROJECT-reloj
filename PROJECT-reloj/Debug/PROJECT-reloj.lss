                                 //----------------------------------------------------------------------------------------------DISPF
                                 // toda la logica para el funcionamiento de los displays
                                 DISPF:
                                 
000385 3001                      	CPI R16, 1
000386 f011                          BREQ MESDIA
                                     
000387 3000                          CPI R16, 0
000388 f019                          BREQ HORAMIN
                                 
                                 MESDIA:
000389 940e 00d8                 	CALL LOADDMINV
00038b c002                      	RJMP DISPSELCALC
                                 HORAMIN:
00038c 940e 00c6                 	CALL LOADHM
                                 
                                 DISPSELCALC:
                                 
00038e 3054                          CPI R21, 4
00038f f010                      	BRLO DISPSEL     // Si R21 < 4, está bien
000390 2755                          CLR R21          // Si R21 >= 4, resetea a 0    
000391 9508                      	RET
                                 
                                 DISPSEL:
000392 940e 0396                 	CALL DISPLAYSEL
000394 9553                      	INC R21 //Va haciendo la cuenta para actulizar los contadores individualmente
000395 9508                          RET
                                 
                                 DISPLAYSEL:
                                 
000396 3050                          CPI R21, 0 // Compara con 0
000397 f031                          BREQ DISP0 // Salta a DISP0 si R21 = 0
000398 3051                          CPI R21, 1 // Compara con 1
000399 f051                          BREQ DISP1 // Salta a DISP1 si R21 = 1
00039a 3052                          CPI R21, 2 // Compara con 2
00039b f071                          BREQ DISP2 // Salta a DISP2 si R21 = 2
00039c 3053                          CPI R21, 3 // Compara con 3
00039d f091                          BREQ DISP3 // Salta a DISP3 si R21 = 3
                                 	//nunca deberia pasar sin saltar
                                 
                                 DISP0:
00039e 985c                          CBI PORTD, 4    // Apaga PD4
00039f 985d                          CBI PORTD, 5    // Apaga PD5
0003a0 985e                          CBI PORTD, 6    // Apaga PD6
0003a1 9a5b                          SBI PORTD, 3    // Enciende PD3 (DISP0)
0003a2 2f72                      	MOV R23, R18	// Cuenta de Unidades S a R23
0003a3 c012                      	RJMP DISPLAY
                                 
                                 DISP1:
0003a4 985b                          CBI PORTD, 3    // Apaga PD3
0003a5 985d                          CBI PORTD, 5    // Apaga PD5
0003a6 985e                          CBI PORTD, 6    // Apaga PD6
0003a7 9a5c                          SBI PORTD, 4    // Enciende PD4 (DISP1)
0003a8 2f76                      	MOV R23, R22	// Cuenta de Decenas S a R23
0003a9 c00c                          RJMP DISPLAY
                                 
                                 DISP2:
0003aa 985b                          CBI PORTD, 3    // Apaga PD3
0003ab 985c                          CBI PORTD, 4    // Apaga PD4
0003ac 985e                          CBI PORTD, 6    // Apaga PD6
0003ad 9a5d                          SBI PORTD, 5    // Enciende PD5 (DISP2)
0003ae 2f78                      	MOV R23, R24	// Cuenta de Unidades S a R23
0003af c006                          RJMP DISPLAY
                                 
                                 DISP3:
0003b0 985b                          CBI PORTD, 3    // Apaga PD3
0003b1 985c                          CBI PORTD, 4    // Apaga PD4
0003b2 985d                          CBI PORTD, 5    // Apaga PD5
0003b3 9a5e                          SBI PORTD, 6    // Enciende PD6 (DISP3)
0003b4 2f7a                      	MOV R23, R26	// Cuenta de Decenas S a R23
0003b5 c000                          RJMP DISPLAY
                                 
                                 DISPLAY:
0003b6 934f                      	PUSH R20
0003b7 93ff                      	PUSH ZH
0003b8 93ef                          PUSH ZL
                                 
0003b9 e0f9                          LDI ZH, HIGH(disp7seg << 1)
0003ba ece8                          LDI ZL, LOW(disp7seg << 1)
                                 
                                 	// busca los valores para el 7 segmentos
0003bb 0f77                      	LSL R23		//mueve los bits a la iz (multiplica por 2)
0003bc 0fe7                      	ADD ZL, R23
0003bd e040                      	LDI R20, 0
0003be 1ff4                      	ADC ZH, R20
0003bf 9174                      	LPM R23, Z
                                 
0003c0 91ef                      	POP ZL
0003c1 91ff                          POP ZH
0003c2 914f                      	POP R20
                                 
                                 	//Actualiza todo el portC (6 segmentos)
0003c3 2f97                      	MOV R25, R23
0003c4 b998                      	OUT PORTC, R25  
                                 	//Actualiza el ultimo segmento
0003c5 fd96                      	SBRC R25, 6
0003c6 9a5a                          SBI PORTD, PORTD2
0003c7 ff96                          SBRS R25, 6
0003c8 985a                          CBI PORTD, PORTD2
                                 
                                 	//Limpia para que no afecte los otros diplays
0003c9 2799                      	CLR R25
0003ca b998                      	OUT PORTC, R25  
                                 	//Actualiza el ultimo segmento
0003cb fd96                      	SBRC R25, 6
0003cc 9a5a                          SBI PORTD, PORTD2
0003cd ff96                          SBRS R25, 6
0003ce 985a                          CBI PORTD, PORTD2 
0003cf 9508                      RET
                                 
                                 
                                 // -----------------------------------------------------------------------------------------------------TIEMPO
                                 // Toda la logica de la cuenta del tiempo
                                 TIEMPO:
                                 	
0003d0 940e 00c6                 	CALL LOADHM
                                 	
                                 	// modos con la cuenta interrumpida
0003d2 3042                      	CPI R20, 2
0003d3 f010                          BRLO Sicontar
0003d4 2711                      	CLR	R17
0003d5 c003                      	RJMP Nocontar
                                 	Sicontar:
                                 
0003d6 3716                      	CPI R17, 118 //segundos (118) (1 para pruebas de dia y mes)
0003d7 f0c0                          BRLO TIMER_RET
0003d8 2711                      	CLR R17
                                 
                                 	Nocontar:
                                 
                                 	//Unidades de Minutos
0003d9 9523                      	INC R18
0003da 302a                          CPI R18, 10
0003db f0a0                          BRLO TIMER_RET
0003dc 2722                      	CLR R18
                                 
0003dd 9563                      	INC R22			//Decenas de Minutos
0003de 3066                      	CPI R22, 6
0003df f080                      	BRLO TIMER_RET
0003e0 2766                      	CLR R22
                                 
0003e1 9583                      	INC R24			//Unidades de Horas
0003e2 30a2                      	CPI R26, 2	
0003e3 f421                      	BRNE ZEROoDIEZ // revisa que no ha llegado a 20
0003e4 3084                      	CPI R24, 4
0003e5 f050                      	BRLO TIMER_RET
0003e6 2788                      	CLR R24
0003e7 c003                      	RJMP DECENASdeHORAS
                                 ZEROoDIEZ:
0003e8 308a                      	CPI R24, 10
0003e9 f030                      	BRLO TIMER_RET
0003ea 2788                      	CLR R24
                                 
                                 DECENASdeHORAS:
0003eb 95a3                      	INC R26			//Decenas de Horas
0003ec 30a3                      	CPI R26, 3
0003ed f010                      	BRLO TIMER_RET
0003ee 27aa                      	CLR R26
0003ef 95b3                      	INC R27
                                 
                                 TIMER_RET:
                                 	//Ahora cambio para hacer lo de los dias
0003f0 940e 00e1                 	CALL SAVEHM
0003f2 940e 00cf                 	CALL LOADDM
                                 DIA:
                                 	// Verificar carry (ya paso un dia?)
0003f4 30b0                      	CPI R27, 0
0003f5 f0f1                      	BREQ TEMPORAL	  // Si R27 es 0, (no cambio nada en MES/DIA asi que sale)
0003f6 9523                      	INC R18           // Si R27 está activo, sumar 1 a R18
0003f7 27bb                      	CLR R27
                                 
0003f8 940e 044e                 	CALL LOGDIAS			//para ver como se debe efectuar la suma de dias
                                 
0003fa 91c0 0110                 	LDS R28, Mes
0003fc 30c0                      	CPI R28, 0  
0003fd f139                          BREQ TREINTA_Y_UN_DIAS
                                     
0003fe 30c1                          CPI R28, 1
0003ff f011                          BREQ TREINTA_DIAS
                                     
000400 30c2                          CPI R28, 2  
000401 f099                          BREQ VEINTIOCHO_DIAS
                                 
                                 
                                 TREINTA_DIAS: // Aquí va la lógica para meses de 30 días ----------------------------------------------
