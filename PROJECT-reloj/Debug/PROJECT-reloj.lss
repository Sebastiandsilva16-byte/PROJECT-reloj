                                 //--------------------------------------------------------------------------------------------------------LOGICA DE DIAS
                                 // Mes-->  (0) 31 dias (1) 30 dias (2) 28 dias
                                 LOGDIAS:
                                 	// Verificar condiciones para saltar a 30dias
000512 3084                      	CPI R24, 4        // żR24 es 4 (abril)?
000513 f081                      	BREQ MESUNO
000514 3086                      	CPI R24, 6        // żR24 es 6 (junio)?
000515 f071                      	BREQ MESUNO
000516 3089                      	CPI R24, 9        // żR24 es 9 (septiembre)?
000517 f061                      	BREQ MESUNO
                                 
                                 	// Verificar si R26=1 y R24=1 (noviembre)
